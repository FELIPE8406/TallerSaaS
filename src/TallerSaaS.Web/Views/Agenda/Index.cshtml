@{
    ViewData["Title"] = "Agenda y Citas";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Agenda de Citas</h1>
            <p class="text-muted">Gestión de disponibilidad y programación por mecánico</p>
        </div>
        <div>
            <button class="btn btn-primary" onclick="openAppointmentModal()">
                <i class="bi bi-calendar-plus me-2"></i>Nueva Cita
            </button>
        </div>
    </div>

    <!-- Modernized Calendar Interface -->
    <script>
        // Critical: Provide scale data immediately for the dispatcher
        window.mechanicsData = @Html.Raw(Json.Serialize(ViewBag.Mechanics));
    </script>
    <div class="card shadow-sm border-0 mb-4 overflow-hidden" style="border-radius: 16px;">
        <div class="card-body p-3" style="min-height: 700px;">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Appointment Modal -->
<div class="modal fade" id="appointmentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Nueva Cita</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="appointmentForm">
                    <input type="hidden" id="appointmentId" name="Id" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Cliente</label>
                            <select class="form-select" id="clienteId" name="ClienteId" required onchange="loadVehiculos()">
                                <option value="">Seleccione un cliente...</option>
                                @foreach (var c in ViewBag.Clientes)
                                {
                                    <option value="@c.Id">@c.NombreCompleto</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Vehículo</label>
                            <select class="form-select" id="vehiculoId" name="VehiculoId" required>
                                <option value="">Seleccione primero un cliente...</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-primary">Mecánico Asignado</label>
                            <select class="form-select" id="mechanicId" name="MechanicId" required>
                                <option value="">Seleccione un mecánico...</option>
                                @foreach (var m in ViewBag.Mechanics)
                                {
                                    <option value="@m.Id">@m.NombreCompleto</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Tipo de Servicio</label>
                            <input type="text" class="form-control" id="serviceType" name="ServiceType" placeholder="Ej: Cambio de Aceite" required />
                        </div>
                        
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Fecha y Hora Inicio</label>
                            <input type="datetime-local" class="form-control" id="startDateTime" name="StartDateTime" required onchange="calculateEndTime()" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Duración Est. (min)</label>
                            <input type="number" class="form-control" id="estimatedDuration" name="EstimatedDuration" value="60" required oninput="calculateEndTime()" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Hora Fin (Automática)</label>
                            <input type="datetime-local" class="form-control bg-light" id="endDateTime" name="EndDateTime" readonly />
                        </div>
                        
                        <div class="col-12" id="statusContainer" style="display:none">
                            <label class="form-label small fw-bold">Estado de la Cita</label>
                            <select class="form-select" id="status" name="Status">
                                <option value="1">Confirmada</option>
                                <option value="2">En Taller (Checked-In)</option>
                                <option value="3">No Asistió</option>
                                <option value="4">Completada</option>
                                <option value="5">Cancelada</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <div class="me-auto" id="appointmentActions" style="display:none">
                    <button type="button" class="btn btn-outline-success btn-sm" onclick="convertToOrder()">
                        <i class="bi bi-file-earmark-plus me-1"></i>Convertir a Orden
                    </button>
                    <button type="button" class="btn btn-outline-info btn-sm" onclick="sendWhatsapp()">
                        <i class="bi bi-whatsapp me-1"></i>Enviar Recordatorio
                    </button>
                </div>
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary px-4" onclick="saveAppointment()">Guardar Cita</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <!-- FullCalendar CSS -->
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css' rel='stylesheet' />
    <style>
        .fc { max-height: 850px; font-family: 'Inter', sans-serif; border: none; }
        .fc-theme-bootstrap5 a { color: var(--text); text-decoration: none; }
        .fc-header-toolbar { padding: 1.5rem; background: var(--surface); margin-bottom: 0 !important; }
        .fc-view-harness { background: var(--surface2); padding: 10px; }
        .fc-col-header-cell { background: var(--surface); padding: 10px 0 !important; }
        .fc-timegrid-slot { height: 50px !important; border-bottom: 1px solid var(--border) !important; }
        .fc-event { 
            border-radius: 8px !important; 
            padding: 4px 8px !important; 
            font-size: 0.85rem !important; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border: none !important;
            margin: 2px !important;
        }
        .fc-v-event .fc-event-main { color: white !important; }
        .fc-resource-timeline-lane { height: 100px; }
        .modal-content { border-radius: 16px; border: none; }
        .btn-primary { border-radius: 10px; padding: 0.6rem 1.5rem; font-weight: 600; }
        
        /* Custom Colors for Mechanic Resources */
        .mech-color-1 { background-color: #4e73df !important; }
        .mech-color-2 { background-color: #1cc88a !important; }
        .mech-color-3 { background-color: #36b9cc !important; }
        .mech-color-4 { background-color: #f6c23e !important; }
        .mech-color-5 { background-color: #e74a3b !important; }
    </style>
}

<!-- Scripts moved to body to support SPA re-execution -->
<script>
    (function() {
        var calendar;
        var appointmentModal;
        window.initAgenda = function(retryCount = 0) {
            console.log('Antigravity: Initializing Agenda... Attempt: ' + (retryCount + 1));
            
            if (typeof FullCalendar === 'undefined') {
                if (retryCount < 10) {
                    setTimeout(() => window.initAgenda(retryCount + 1), 200);
                    return;
                }
                console.error('Antigravity: FullCalendar not loaded after 10 retries.');
                return;
            }

            var calendarEl = document.getElementById('calendar');
            var modalEl = document.getElementById('appointmentModal');
            
            if (modalEl && typeof bootstrap !== 'undefined' && !appointmentModal) {
                appointmentModal = new bootstrap.Modal(modalEl);
                console.log('Antigravity: Modal initialized.');
            }

            if (!calendarEl) {
                if (retryCount < 10) {
                    setTimeout(() => window.initAgenda(retryCount + 1), 200);
                }
                return;
            }

            // Ensure clean state for SPA re-initialization
            if (calendar) {
                try { calendar.destroy(); } catch(e) {}
            }
            calendarEl.innerHTML = '';

            // 2. Initialize Calendar (decoupled with internal retry)
            let fcRetryCount = 0;
            const tryRenderCalendar = () => {
                if (typeof FullCalendar !== 'undefined') {
                    console.log('Antigravity: FullCalendar found, rendering...');
                    var mechanicsData = window.mechanicsData || [];
                    var resData = mechanicsData.map(m => ({ 
                        id: m.id || m.Id, 
                        title: m.nombreCompleto || m.NombreCompleto,
                        businessHours: m.businessHours || m.BusinessHours
                    }));
                    
                    if (calendar) {
                        calendar.destroy();
                        console.log('Antigravity: Old calendar destroyed for clean re-render.');
                    }

                    calendar = new FullCalendar.Calendar(calendarEl, {
                        initialView: 'resourceTimeGridWeek',
                        themeSystem: 'bootstrap5',
                        height: 'auto',
                        contentHeight: 'auto',
                        handleWindowResize: true,
                        expandRows: true,
                        locale: 'es',
                        businessHours: true,
                        hiddenDays: [0], // Ocultar Domingo por defecto para "Semana Laboral"
                        slotMinTime: '07:00:00',
                        slotMaxTime: '19:00:00',
                        allDaySlot: false,
                        nowIndicator: true,
                        headerToolbar: {
                            left: 'prev,next today',
                            center: 'title',
                            right: 'resourceTimeGridWeek,resourceTimeGridDay,dayGridMonth'
                        },
                        resources: resData,
                        events: '/Agenda/GetAppointments',
                        editable: true,
                        selectable: true,
                        select: function(info) {
                            window.openAppointmentModal({
                                startDateTime: info.startStr.substring(0, 16),
                                mechanicId: info.resource ? info.resource.id : ''
                            });
                        },
                        eventDidMount: function(info) {
                            const resId = info.event.getResources()[0]?.id;
                            if (resId && window.mechanicsData) {
                                const idx = window.mechanicsData.findIndex(m => (m.id || m.Id) === resId);
                                if (idx !== -1) info.el.classList.add('mech-color-' + ((idx % 5) + 1));
                            }
                        },
                        eventClick: function(info) { editAppointment(info.event); },
                        eventDrop: function(info) { updateAppointmentTime(info.event); },
                        eventResize: function(info) { updateAppointmentTime(info.event); }
                    });
                    calendar.render();
                    setTimeout(() => { if(calendar) calendar.updateSize(); }, 500);
                    console.log('Antigravity: Calendar render() called.');
                } else if (fcRetryCount < 15) {
                    fcRetryCount++;
                    console.log('Antigravity: Retrying FullCalendar render... (' + fcRetryCount + ')');
                    setTimeout(tryRenderCalendar, 400);
                } else {
                    console.error('Antigravity: FATAL - FullCalendar script not accessible globally.');
                    calendarEl.innerHTML = '<div class="alert alert-danger">Error: No se pudo cargar el motor del calendario. Por favor, refresca la página (F5).</div>';
                }
            };
            
            tryRenderCalendar();
        }

        // Helper to format string to 12h time (AM/PM) WITHOUT any timezone shifts
        function formatTime12h(timeStr) {
            if (!timeStr) return '--:--';
            
            // Handle various formats: "2026-03-18T09:10:00" or "2026-03-18 09:10:00"
            let timePart = "";
            if (timeStr.includes('T')) {
                timePart = timeStr.split('T')[1];
            } else if (timeStr.includes(' ')) {
                timePart = timeStr.split(' ')[1];
            } else {
                timePart = timeStr; // Fallback if only time provided
            }
            
            if (!timePart) return '--:--';
            
            // Get HH:mm
            const hh_mm = timePart.substring(0, 5);
            const bits = hh_mm.split(':');
            if (bits.length < 2) return '--:--';
            
            let hour = parseInt(bits[0]);
            const mm = bits[1];
            const ampm = hour >= 12 ? 'PM' : 'AM';
            hour = hour % 12;
            hour = hour ? hour : 12; // 0 becomes 12
            
            return `${String(hour).padStart(2, '0')}:${mm} ${ampm}`;
        }

        window.openAppointmentModal = function(defaults = {}) {
            const form = document.getElementById('appointmentForm');
            if (form) form.reset();
            const idEl = document.getElementById('appointmentId');
            if (idEl) idEl.value = '';
            const titleEl = document.getElementById('modalTitle');
            if (titleEl) titleEl.innerText = 'Nueva Cita';
            const statusCont = document.getElementById('statusContainer');
            if (statusCont) statusCont.style.display = 'none';
            const actionsCont = document.getElementById('appointmentActions');
            if (actionsCont) actionsCont.style.display = 'none';
            if (defaults.startDateTime) {
                const sdt = document.getElementById('startDateTime');
                if (sdt) sdt.value = defaults.startDateTime;
                if (typeof calculateEndTime === 'function') calculateEndTime();
            }
            if (defaults.mechanicId) {
                const mId = document.getElementById('mechanicId');
                if (mId) mId.value = defaults.mechanicId;
            }
            if (appointmentModal) appointmentModal.show();
        };

        window.editAppointment = async function(event) {
            const idEl = document.getElementById('appointmentId');
            if (idEl) idEl.value = event.id;
            const titleEl = document.getElementById('modalTitle');
            if (titleEl) titleEl.innerText = 'Editar Cita';
            const statusCont = document.getElementById('statusContainer');
            if (statusCont) statusCont.style.display = 'block';
            const actionsCont = document.getElementById('appointmentActions');
            if (actionsCont) actionsCont.style.display = 'block';
            
            const stEl = document.getElementById('serviceType');
            if (stEl) stEl.value = event.extendedProps.serviceType;
            const sdt = document.getElementById('startDateTime');
            if (sdt) sdt.value = event.startStr.substring(0, 16);
            const edt = document.getElementById('endDateTime');
            if (edt) edt.value = event.endStr.substring(0, 16);
            
            const mId = document.getElementById('mechanicId');
            if (mId) mId.value = event.getResources()[0]?.id || '';
            const sEl = document.getElementById('status');
            if (sEl) sEl.value = event.extendedProps.status;
            
            const clientId = event.extendedProps.clienteId;
            if (clientId) {
                const cIdEl = document.getElementById('clienteId');
                if (cIdEl) cIdEl.value = clientId;
                await window.loadVehiculos();
                const vIdEl = document.getElementById('vehiculoId');
                if (vIdEl) vIdEl.value = event.extendedProps.vehiculoId;
            }
            if (appointmentModal) appointmentModal.show();
        };

        window.saveAppointment = async function() {
            const form = document.getElementById('appointmentForm');
            if (!form || !form.checkValidity()) { if(form) form.reportValidity(); return; }
            const formData = new FormData(form);
            const payload = {};
            formData.forEach((value, key) => {
                if (key === 'Id' && !value) { payload[key] = '00000000-0000-0000-0000-000000000000'; }
                else if (!isNaN(value) && value !== '' && key !== 'MechanicId') { payload[key] = Number(value); }
                else { payload[key] = value; }
            });
            payload.StartDateTime = document.getElementById('startDateTime').value;
            payload.EndDateTime = document.getElementById('endDateTime').value;
            const response = await fetch('/Agenda/SaveAppointment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (result.success) {
                if (appointmentModal) appointmentModal.hide();
                if (calendar) calendar.refetchEvents();
            } else if (typeof Swal !== 'undefined') {
                Swal.fire('Error', result.message, 'error');
            }
        };

        window.updateAppointmentTime = async function(event) {
            const payload = {
                id: event.id,
                mechanicId: event.getResources()[0]?.id,
                startDateTime: event.startStr,
                endDateTime: event.endStr,
                serviceType: event.extendedProps.serviceType,
                status: event.extendedProps.status
            };
            const response = await fetch('/Agenda/SaveAppointment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (!result.success) {
                if (calendar) calendar.refetchEvents();
                if (typeof Swal !== 'undefined') Swal.fire('Error', result.message, 'error');
            }
        };

        window.convertToOrder = async function() {
            const id = document.getElementById('appointmentId').value;
            let confirmed = true;
            if (typeof Swal !== 'undefined') {
                const result = await Swal.fire({
                    title: '¿Convertir a Orden?',
                    text: 'Se creará una nueva orden de servicio y se marcará la cita como completada.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, crear orden'
                });
                confirmed = result.isConfirmed;
            }
            if (confirmed) {
                const res = await fetch('/Agenda/ConvertToOrder?id=' + id, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    if (appointmentModal) appointmentModal.hide();
                    if (calendar) calendar.refetchEvents();
                    setTimeout(() => window.location.href = '/Ordenes/Detalle/' + data.orderId, 1500);
                } else if (typeof Swal !== 'undefined') {
                    Swal.fire('Error', data.message, 'error');
                }
            }
        };

        window.loadVehiculos = async function() {
            const clienteId = document.getElementById('clienteId').value;
            const select = document.getElementById('vehiculoId');
            if (!select) return;
            select.innerHTML = '<option value="">Cargando...</option>';
            if (!clienteId) return;
            const res = await fetch('/Agenda/GetVehiculos?clienteId=' + clienteId);
            const data = await res.json();
            select.innerHTML = data.length ? '' : '<option value="">No hay vehículos registrados</option>';
            data.forEach(v => {
                const opt = document.createElement('option');
                opt.value = v.id; opt.innerText = v.descripcion; select.appendChild(opt);
            });
        };

        window.calculateEndTime = function() {
            const start = document.getElementById('startDateTime').value;
            const durationEl = document.getElementById('estimatedDuration');
            const duration = durationEl ? parseInt(durationEl.value) : 0;
            if (!start || isNaN(duration)) return;
            const startDate = new Date(start);
            const endDate = new Date(startDate.getTime() + duration * 60000);
            const yyyy = endDate.getFullYear();
            const mm = String(endDate.getMonth() + 1).padStart(2, '0');
            const dd = String(endDate.getDate()).padStart(2, '0');
            const hh = String(endDate.getHours()).padStart(2, '0');
            const min = String(endDate.getMinutes()).padStart(2, '0');
            const edt = document.getElementById('endDateTime');
            if (edt) edt.value = yyyy + '-' + mm + '-' + dd + 'T' + hh + ':' + min;
        };

        window.editAppointmentFromList = function(id) {
            if (calendar) {
                const event = calendar.getEventById(id);
                if (event) window.editAppointment(event);
            }
        };
    })();
</script>
