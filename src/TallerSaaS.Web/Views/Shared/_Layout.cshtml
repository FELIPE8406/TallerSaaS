@using TallerSaaS.Shared.Helpers
@inject TallerSaaS.Domain.Interfaces.ICurrentTenantService TenantService
<!DOCTYPE html>
<html lang="es" data-bs-theme="@(User.IsInRole("SuperAdmin") ? "dark" : "light")">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="GEARDASH — Sistema de Gestión para Talleres Automotrices en Colombia" />
  <title>@ViewData["Title"] - GEARDASH</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/TallerSaaS.Web.styles.css" asp-append-version="true" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <!-- FullCalendar Engine moved to global for SPA reliability -->
  <script src='https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@6.1.10/index.global.min.js' defer></script>
  @RenderSection("Styles", required: false)
</head>
<body>
  @if (User.Identity?.IsAuthenticated == true)
  {
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <div class="logo-icon">T</div>
        <span class="logo-text">GEARDASH</span>
      </div>
      <nav class="sidebar-nav">
        @if (User.IsInRole("SuperAdmin"))
        {
          <div class="sidebar-section-title">Administración</div>
          <a asp-controller="SuperAdmin" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuperAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="bi bi-speedometer2 nav-icon"></i><span class="nav-label">Panel Global</span>
          </a>
          <a asp-controller="SuperAdmin" asp-action="Tenants"
             class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Tenants" ? "active" : "")">
            <i class="bi bi-buildings nav-icon"></i><span class="nav-label">Talleres</span>
          </a>
          <a asp-controller="SuperAdmin" asp-action="Planes"
             class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Planes" ? "active" : "")">
            <i class="bi bi-card-list nav-icon"></i><span class="nav-label">Planes</span>
          </a>
          <a asp-controller="SuperAdmin" asp-action="Pagos"
             class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Pagos" ? "active" : "")">
            <i class="bi bi-credit-card nav-icon"></i><span class="nav-label">Pagos</span>
          </a>
        }
        else
        {
          <div class="sidebar-section-title">General</div>
          <a asp-controller="Dashboard" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2 nav-icon"></i><span class="nav-label">Dashboard</span>
          </a>
          <a asp-controller="Clientes" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clientes" ? "active" : "")">
            <i class="bi bi-people nav-icon"></i><span class="nav-label">Clientes</span>
          </a>
          <a asp-controller="Vehiculos" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehiculos" ? "active" : "")">
            <i class="bi bi-car-front nav-icon"></i><span class="nav-label">Vehículos</span>
          </a>
          <a asp-controller="Agenda" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agenda" ? "active" : "")">
            <i class="bi bi-calendar3 nav-icon"></i><span class="nav-label">Agenda</span>
          </a>
          <a asp-controller="Usuarios" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")">
            <i class="bi bi-person-gear nav-icon"></i><span class="nav-label">Equipo</span>
          </a>
          <div class="sidebar-section-title">Operaciones</div>
          <a asp-controller="Ordenes" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ordenes" ? "active" : "")">
            <i class="bi bi-file-earmark-text nav-icon"></i><span class="nav-label">Órdenes</span>
          </a>
          <a asp-controller="Facturas" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Facturas" ? "active" : "")">
            <i class="bi bi-receipt nav-icon"></i><span class="nav-label">Facturas</span>
          </a>
          <div class="sidebar-section-title">Inventario</div>
          <a asp-controller="Inventario" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventario" ? "active" : "")">
            <i class="bi bi-box-seam nav-icon"></i><span class="nav-label">Inventario</span>
          </a>
          <a asp-controller="Bodega" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bodega" ? "active" : "")">
            <i class="bi bi-building nav-icon"></i><span class="nav-label">Bodegas</span>
          </a>
          
          <div class="sidebar-section-title">Finanzas</div>
          @if (TenantService.PlanId == 3)
          {
            <a asp-controller="Nomina" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Nomina" ? "active" : "")">
              <i class="bi bi-wallet2 nav-icon"></i><span class="nav-label">Nómina Electrónica</span>
            </a>
            <a asp-controller="EmpleadoContrato" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "EmpleadoContrato" ? "active" : "")">
              <i class="bi bi-people nav-icon"></i><span class="nav-label">Gestión de Personal</span>
            </a>
          }
          else
          {
            <a asp-controller="Nomina" asp-action="Upgrade" class="nav-item-link text-muted opacity-75">
              <i class="bi bi-lock-fill nav-icon text-warning"></i><span class="nav-label">Nómina <span class="badge bg-warning text-dark ms-1" style="font-size:9px;">PRO</span></span>
            </a>
          }
          @if (TenantService.PlanId == 3 || User.IsInRole("SuperAdmin"))
          {
            <div class="sidebar-section-title">Contabilidad</div>
            <a asp-controller="Contabilidad" asp-action="Index"
               class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contabilidad" ? "active" : "")">
              <i class="bi bi-calculator nav-icon"></i><span class="nav-label">Módulo Contable</span>
            </a>
          }
          <div class="sidebar-section-title">Reportes</div>
          <a asp-controller="Reportes" asp-action="Index"
             class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reportes" ? "active" : "")">
            <i class="bi bi-bar-chart-line nav-icon"></i><span class="nav-label">Exportar Reportes</span>
          </a>
        }
      </nav>
      <div class="sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0" class="no-spa">
          @Html.AntiForgeryToken()
          <button type="submit" class="nav-item-link w-100" style="background:none;border:none;text-align:left;cursor:pointer;color:#FF3B30;">
            <i class="bi bi-box-arrow-left nav-icon"></i>
            <span class="nav-label">Cerrar Sesión</span>
          </button>
        </form>
      </div>
    </aside>

    <div class="main-wrapper d-flex flex-column">
      <header class="topbar">
        <button class="btn-toggle-sidebar" onclick="toggleSidebar()" aria-label="Menú">
          <i class="bi bi-list"></i>
        </button>
        <div class="topbar-left ms-3">
             @await Component.InvokeAsync("HeaderIdentity")
        </div>
        <div class="topbar-right">
          <div class="user-pill">
            <div class="user-avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")</div>
            <div class="d-none d-md-block">
              <div class="user-name">@User.Identity?.Name</div>
              <div class="user-role">
                @if (User.IsInRole("SuperAdmin")) { <text>Super Admin</text> }
                else if (User.IsInRole("Admin")) { <text>Administrador</text> }
                else { <text>Mecánico</text> }
              </div>
            </div>
          </div>
        </div>
      </header>

      <main class="page-content d-flex flex-column gap-3 w-100">
        @if (TempData["Exito"] != null)
        {
          <div class="alert alert-success alert-flash">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
          </div>
        }
        @if (TempData["Error"] != null)
        {
          <div class="alert alert-danger alert-flash">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@Html.Raw(TempData["Error"])
          </div>
        }
        @if (TempData["Info"] != null)
        {
          <div class="alert alert-info alert-flash">
            <i class="bi bi-info-circle-fill me-2"></i>@Html.Raw(TempData["Info"])
          </div>
        }
        @{
          var soporteTenantNombre = Context.Session.GetString("ImpersonatedTenantNombre");
        }
        @if (!string.IsNullOrEmpty(soporteTenantNombre))
        {
          <div style="background:linear-gradient(90deg,#FF9F0A,#FF6B00);color:#fff;
                      padding:8px 20px;border-radius:10px;margin-bottom:14px;
                      display:flex;align-items:center;justify-content:space-between;
                      font-size:13px;font-weight:600;box-shadow:0 3px 12px rgba(255,149,0,.3);">
            <span>
              🛡&nbsp; <strong>Modo Soporte activo</strong> —
              Navegando como: <em>@soporteTenantNombre</em>
            </span>
            <form asp-controller="SuperAdmin" asp-action="TerminarSoporte"
                  method="post" style="margin:0;">
              @Html.AntiForgeryToken()
              <button type="submit"
                      style="background:rgba(255,255,255,0.25);color:#fff;border:1.5px solid rgba(255,255,255,0.5);
                             border-radius:8px;padding:4px 14px;font-size:12px;font-weight:700;cursor:pointer;">
                Terminar Soporte ✕
              </button>
            </form>
          </div>
        }
        @RenderBody()
      </main>
    </div>
  }
  else
  {
    @RenderBody()
  }

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
  <script src="~/js/site.js" asp-append-version="true" defer></script>
  <script src="~/js/sura-paginator.js" asp-append-version="true" defer></script>
  
  @RenderSection("Scripts", required: false)
</body>
</html>
