@{
    ViewData["Title"] = "Error";
}

<div class="page-header">
    <h1 class="page-title text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Error</h1>
</div>

<div class="card-custom p-4" style="max-width:500px;">
    <h5>Se produjo un error inesperado.</h5>
    <p style="color:var(--text-muted);">Por favor intenta de nuevo o contacta al soporte.</p>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
        <i class="bi bi-house me-1"></i>Ir al Dashboard
    </a>
</div>
