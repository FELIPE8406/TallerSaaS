@{ ViewData["Title"] = "Nómina Electrónica"; }

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Nómina Electrónica</h1>
            <p class="text-muted">Gestión de pagos, comisiones y rentabilidad de mecánicos (Plan Empresarial).</p>
        </div>
        <button class="btn btn-primary" id="btnGenerarNomina">
            <i class="fas fa-plus mr-2"></i>Generar Nómina
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Nómina (Mes)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-total-nomina">$0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-money-bill-wave fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Comisiones</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-total-comisiones">$0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-percentage fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Pendientes DIAN</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-pendientes-dian">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Rentabilidad Real</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-rentabilidad">$0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-chart-line fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form id="filter-form" class="row">
                <div class="col-md-3">
                    <label class="small">Período (Mes/Año)</label>
                    <input type="month" id="filter-period" class="form-control" value="@DateTime.Now.ToString("yyyy-MM")">
                </div>
                <div class="col-md-3">
                    <label class="small">Estado</label>
                    <select id="filter-status" class="form-control">
                        <option value="">Todos los Estados</option>
                        <option value="Draft">Borrador</option>
                        <option value="Paid">Pagado</option>
                        <option value="Reported">Reportado a la DIAN</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small">Empleado</label>
                    <select id="filter-mechanic" class="form-control">
                        <option value="">Todos los Empleados</option>
                        @if (ViewBag.Mechanics != null)
                        {
                            foreach (var mech in (IEnumerable<(string Id, string Name)>)ViewBag.Mechanics)
                            {
                                <option value="@mech.Id">@mech.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" class="btn btn-secondary w-100 btn-aplicar-filtros">
                        <i class="fas fa-search mr-2"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="nomina-table">
                    <thead class="bg-light">
                        <tr>
                            <th>Empleado</th>
                            <th>Período</th>
                            <th>Neto a Pagar</th>
                            <th>Rentabilidad</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="nomina-body">
                        <!-- AJAX content -->
                    </tbody>
                </table>
            </div>
            <div id="pagination-container" class="mt-3"></div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalDetalleNomina" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div id="modalContent"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/nomina.js" asp-append-version="true"></script>
}
