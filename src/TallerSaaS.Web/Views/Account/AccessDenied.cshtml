@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<style>
/* ── Apple-style Access Denied — scoped ─────────────────── */
.access-denied-wrap {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
}
.access-denied-card {
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid rgba(210, 210, 215, 0.6);
    border-radius: 24px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
    padding: 3rem 2.5rem;
    max-width: 440px;
    width: 100%;
    text-align: center;
}
.access-denied-icon {
    width: 72px;
    height: 72px;
    border-radius: 20px;
    background: linear-gradient(135deg, #FF453A 0%, #FF6B63 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 6px 20px rgba(255, 69, 58, 0.25);
}
.access-denied-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #1C1C1E;
    margin-bottom: 0.5rem;
}
.access-denied-sub {
    font-size: 0.9rem;
    color: #6E6E73;
    line-height: 1.6;
    margin-bottom: 2rem;
}
.access-denied-code {
    display: inline-block;
    background: #F9F9FB;
    border: 1px solid #E5E5EA;
    border-radius: 8px;
    padding: 2px 10px;
    font-family: 'SF Mono', 'Consolas', monospace;
    font-size: 0.78rem;
    color: #FF453A;
    margin-bottom: 1.75rem;
}
.access-denied-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.btn-apple-primary {
    background: #0A84FF;
    color: #fff;
    border: none;
    border-radius: 12px;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    display: block;
}
.btn-apple-primary:hover {
    background: #0070E0;
    color: #fff;
    transform: translateY(-1px);
}
.btn-apple-ghost {
    background: transparent;
    color: #0A84FF;
    border: 1.5px solid #D2D2D7;
    border-radius: 12px;
    padding: 0.7rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    display: block;
}
.btn-apple-ghost:hover {
    border-color: #0A84FF;
    background: rgba(10, 132, 255, 0.04);
}
.access-divider {
    height: 1px;
    background: #F2F2F7;
    margin: 1.5rem 0;
}
</style>

<div class="access-denied-wrap">
    <div class="access-denied-card">

        <!-- Icon -->
        <div class="access-denied-icon">🔒</div>

        <!-- Title -->
        <h1 class="access-denied-title">Acceso Denegado</h1>
        <p class="access-denied-sub">
            No tienes los permisos necesarios para ver este contenido.
            Contacta a tu administrador si crees que esto es un error.
        </p>

        <!-- Error code badge -->
        <span class="access-denied-code">HTTP 403 — Forbidden</span>

        <div class="access-divider"></div>

        <!-- Actions -->
        <div class="access-denied-actions">
            <a href="javascript:history.back()" class="btn-apple-primary">
                ← Volver Atrás
            </a>
            <a asp-controller="Dashboard" asp-action="Index" class="btn-apple-ghost">
                🏠 Ir al Dashboard
            </a>
            @if (User.IsInRole("SuperAdmin"))
            {
                <a asp-controller="SuperAdmin" asp-action="Index" class="btn-apple-ghost">
                    🛡 Panel SuperAdmin
                </a>
            }
        </div>

    </div>
</div>
