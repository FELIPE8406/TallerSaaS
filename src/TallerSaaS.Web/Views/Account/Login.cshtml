@{ Layout = null; }
@using System
@{ ViewData["Title"] = "GEARDASH | Inicio de Sesión"; }
<!DOCTYPE html>
<html lang="es" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - GEARDASH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { --neon-green: #00ff41; --deep-black: #050505; }
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--deep-black);
            margin: 0; padding: 0;
            height: 100vh; width: 100vw;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .bg-container {
            position: fixed; inset: 0; z-index: -1;
            background: linear-gradient(rgba(5, 5, 5, 0.75), rgba(5, 5, 5, 0.85)), url('/images/geardash-bg.png');
            background-size: cover; background-position: center;
            filter: contrast(1.1) brightness(0.8);
        }
        .neon-sweep {
            position: absolute; inset: 0;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 65, 0.03), transparent);
            animation: sweep 8s infinite linear; pointer-events: none;
        }
        @@keyframes sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(200%); } }
        .glass-card {
            background: rgba(10, 10, 10, 0.9);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(0, 255, 65, 0.2);
            box-shadow: 0 0 80px rgba(0, 0, 0, 0.9);
            border-radius: 2rem; width: 100%; max-width: 420px;
        }
        .neo-input {
            background: #0a0a0a !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #fff !important;
        }

        .neo-input:focus {
            background: rgba(20, 20, 20, 1) !important;
            border-color: var(--neon-green) !important;
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.2) !important;
            outline: none !important;
        }

        /* --- Botón de "Iniciar Motor" Neon --- */
        .btn-start-stop {
            background: linear-gradient(135deg, #00ff41 0%, #008f25 100%);
            border: none;
            color: #000 !important; /* Texto negro para contraste máximo */
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 0 20px rgba(0, 255, 65, 0.3);
            cursor: pointer;
        }

        .btn-start-stop:hover {
            transform: scale(1.03) translateY(-3px);
            box-shadow: 0 0 40px rgba(0, 255, 65, 0.6);
            filter: brightness(1.1);
        }

        .btn-start-stop:active {
            transform: scale(0.97);
        }

        /* --- Branding Glow --- */
        .logo-glow {
            filter: drop-shadow(0 0 15px rgba(0, 255, 65, 0.5));
        }

        @@keyframes pulse {
            0%, 100% { opacity: 0.8; }
            50% { opacity: 1; }
        }
        .animate-pulse-glow {
            animation: pulse 2s infinite ease-in-out;
        }

        @@keyframes fade-in {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .animate-fade-in {
            animation: fade-in 1s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }
    </style>
</head>
<body class="text-gray-100">
    <!-- Capa de Fondo Dinámico con Vehículo -->
    <div class="bg-container">
        <div class="neon-sweep"></div>
    </div>

    <div class="w-full max-w-md px-6 animate-fade-up">
        <div class="glass-card p-6 py-8">
            <!-- Sección de Marca -->
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-black border border-[#00ff41]/20 mb-4 logo-glow">
                    <i class="bi bi-gear-wide-connected text-[#00ff41] text-4xl animate-spin-slow" style="animation: spin 10s linear infinite;"></i>
                </div>
                <h1 class="text-4xl font-black italic tracking-tighter text-white uppercase leading-none">
                    GEAR<span class="text-[#00ff41]">DASH</span>
                </h1>
                <p class="text-[#00ff41]/60 text-[10px] mt-3 font-bold tracking-[0.3em] uppercase animate-pulse-glow">
                    Gestión Automotriz de Élite
                </p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded-xl mb-6 text-sm flex items-center gap-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@TempData["Error"]</span>
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="Login" class="space-y-8 no-spa">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Correo Electrónico</label>
                    <div class="relative group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-500 group-focus-within:text-[#00ff41] transition-colors">
                            <i class="bi bi-person-fill"></i>
                        </span>
                        <input type="email" name="email" 
                               class="neo-input w-full pl-11 pr-4 py-4 rounded-2xl text-sm placeholder-gray-700" 
                               placeholder="usuario@geardash.pro" required autocomplete="email" />
                    </div>
                </div>

                <div class="space-y-3">
                    <div class="flex justify-between items-center ml-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Contraseña</label>
                        <a href="#" class="text-[9px] font-bold text-[#00ff41] hover:underline transition-all uppercase tracking-widest">¿Olvidaste?</a>
                    </div>
                    <div class="relative group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-500 group-focus-within:text-[#00ff41] transition-colors">
                            <i class="bi bi-lock-fill"></i>
                        </span>
                        <input type="password" name="password" 
                               class="neo-input w-full pl-11 pr-4 py-4 rounded-2xl text-sm placeholder-gray-700" 
                               placeholder="••••••••" required autocomplete="current-password" />
                    </div>
                </div>

                <div class="flex items-center justify-between pt-2">
                    <label class="inline-flex items-center cursor-pointer group">
                        <input type="checkbox" name="rememberMe" value="true" class="w-4 h-4 rounded border-gray-800 bg-black text-[#00ff41] focus:ring-[#00ff41] transition-all" />
                        <span class="ml-3 text-[11px] font-bold text-gray-500 group-hover:text-gray-300 transition-colors uppercase tracking-wider">Recordarme</span>
                    </label>
                </div>

                <button type="submit" class="btn-start-stop w-full py-5 rounded-2xl flex items-center justify-center gap-3">
                    <i class="bi bi-play-circle-fill text-xl"></i>
                    <span>Iniciar Motores</span>
                </button>
            </form>

            <!-- Separador Or -->
            <div class="flex items-center my-8">
                <div class="flex-grow border-t border-white/5"></div>
                <span class="px-4 text-[9px] font-black text-gray-600 uppercase tracking-widest">O entrar con</span>
                <div class="flex-grow border-t border-white/5"></div>
            </div>

            <!-- Botones Social Logins -->
            <div class="grid grid-cols-2 gap-4">
                <form asp-action="ExternalLogin" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" class="no-spa">
                    @Html.AntiForgeryToken()
                    <button type="submit" name="provider" value="Google" class="w-full flex items-center justify-center gap-2 py-3.5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#00ff41]/30 transition-all group">
                        <i class="bi bi-google text-sm text-gray-400 group-hover:text-white"></i>
                        <span class="text-[10px] font-bold text-gray-500 group-hover:text-white uppercase tracking-wider">Google</span>
                    </button>
                </form>
                <form asp-action="ExternalLogin" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" class="no-spa">
                    @Html.AntiForgeryToken()
                    <button type="submit" name="provider" value="Microsoft" class="w-full flex items-center justify-center gap-2 py-3.5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#00ff41]/30 transition-all group">
                        <i class="bi bi-microsoft text-sm text-gray-400 group-hover:text-white"></i>
                        <span class="text-[10px] font-bold text-gray-500 group-hover:text-white uppercase tracking-wider">Microsoft</span>
                    </button>
                </form>
            </div>

            <div class="mt-8 border-t border-white/5 pt-6 text-center">
                <p class="text-[9px] text-gray-600 uppercase tracking-[0.2em] font-medium opacity-50">
                    GEARDASH Systems &copy; @DateTime.Now.Year <br />
                    Sistema Premium de Gestión Automotriz
                </p>
            </div>
        </div>
    </div>
</body>
</html>
