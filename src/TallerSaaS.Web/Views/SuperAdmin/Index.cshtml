@using TallerSaaS.Application.DTOs
@model SuperAdminDashboardDto
@{
    ViewData["Title"] = "Panel Global SuperAdmin";
    var pctActivos = Model.TotalTenants > 0
        ? (int)Math.Round(Model.TenantsActivos * 100.0 / Model.TotalTenants)
        : 0;
}

<!-- ═══ Page Header ═══════════════════════════════════════════════════════ -->
<div class="sa-page-header">
    <div>
        <div class="sa-eyebrow">
            <i class="bi bi-shield-fill-check"></i> SuperAdmin · Consola Global
        </div>
        <h1 class="sa-title">Panel de Control</h1>
        <p class="sa-subtitle">
            Visión ejecutiva · @DateTime.UtcNow.ToString("dddd d 'de' MMMM, yyyy", new System.Globalization.CultureInfo("es-CO"))
        </p>
    </div>
    <div class="sa-header-actions">
        <a asp-action="Tenants" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-buildings me-1"></i>Ver Todos
        </a>
        <a asp-action="NuevoTenant" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Taller
        </a>
    </div>
</div>

<!-- ═══ KPI Grid — 4 Glass Cards ════════════════════════════════════════ -->
<div class="sa-kpi-grid">

    <!-- Total Talleres -->
    <a asp-action="Tenants" class="sa-kpi text-decoration-none">
        <div class="sa-kpi-icon" style="--c:rgba(0,102,204,.1);--ic:#0066CC;">
            <i class="bi bi-buildings"></i>
        </div>
        <div class="sa-kpi-body">
            <div class="sa-kpi-value">@Model.TotalTenants</div>
            <div class="sa-kpi-label">Talleres Registrados</div>
            <div class="sa-kpi-sub">Total acumulado</div>
        </div>
        <i class="bi bi-chevron-right sa-kpi-arrow"></i>
    </a>

    <!-- Activos -->
    <a asp-action="Tenants" class="sa-kpi text-decoration-none">
        <div class="sa-kpi-icon" style="--c:rgba(52,199,89,.1);--ic:#34C759;">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <div class="sa-kpi-body">
            <div class="sa-kpi-value">@Model.TenantsActivos</div>
            <div class="sa-kpi-label">Talleres Activos</div>
            <div class="sa-kpi-sub">@pctActivos% del total</div>
        </div>
        <i class="bi bi-chevron-right sa-kpi-arrow"></i>
    </a>

    <!-- Ingresos del Mes -->
    <a asp-action="Pagos" class="sa-kpi text-decoration-none">
        <div class="sa-kpi-icon" style="--c:rgba(255,149,0,.1);--ic:#FF9500;">
            <i class="bi bi-graph-up-arrow"></i>
        </div>
        <div class="sa-kpi-body">
            <div class="sa-kpi-value" style="font-size:20px;">$@Model.IngresosMes.ToString("N0")</div>
            <div class="sa-kpi-label">Ingresos del Mes</div>
            <div class="sa-kpi-sub">COP · suscripciones</div>
        </div>
        <i class="bi bi-chevron-right sa-kpi-arrow"></i>
    </a>

    <!-- Ingresos Totales -->
    <a asp-action="Pagos" class="sa-kpi text-decoration-none">
        <div class="sa-kpi-icon" style="--c:rgba(108,108,255,.1);--ic:#6C6CFF;">
            <i class="bi bi-currency-dollar"></i>
        </div>
        <div class="sa-kpi-body">
            <div class="sa-kpi-value" style="font-size:20px;">$@Model.IngresosTotales.ToString("N0")</div>
            <div class="sa-kpi-label">Ingresos Totales</div>
            <div class="sa-kpi-sub">COP · histórico</div>
        </div>
        <i class="bi bi-chevron-right sa-kpi-arrow"></i>
    </a>

</div>

<!-- ═══ Ocupación + Últimos Talleres ════════════════════════════════════ -->
<div class="sa-bottom-grid">

    <!-- Actividad de suscripción (mini gauge) -->
    <div class="sa-card">
        <div class="sa-card-header">
            <div class="sa-card-title">Salud de la Plataforma</div>
        </div>
        <div class="sa-card-body" style="display:flex;flex-direction:column;gap:18px;">

            <!-- Ocupación activos -->
            <div>
                <div class="sa-metric-row">
                    <span class="sa-metric-label">Talleres activos</span>
                    <span class="sa-metric-value" style="color:#34C759;">@pctActivos%</span>
                </div>
                <div class="sa-bar-track">
                    <div class="sa-bar-fill" style="width:@pctActivos%;background:#34C759;"></div>
                </div>
            </div>

            @{
                var pctInactivos = 100 - pctActivos;
            }
            <div>
                <div class="sa-metric-row">
                    <span class="sa-metric-label">Suspendidos / Inactivos</span>
                    <span class="sa-metric-value" style="color:#FF3B30;">@pctInactivos%</span>
                </div>
                <div class="sa-bar-track">
                    <div class="sa-bar-fill" style="width:@pctInactivos%;background:#FF3B30;"></div>
                </div>
            </div>

            <hr style="margin:4px 0;border-color:#F2F2F7;" />

            <!-- Actions rapidas superadmin -->
            <div style="display:flex;flex-direction:column;gap:8px;">
                <a asp-action="NuevoTenant"
                   class="sa-quick-link">
                    <i class="bi bi-building-add"></i>
                    <span>Registrar Nuevo Taller</span>
                    <i class="bi bi-chevron-right ms-auto" style="font-size:12px;color:#AEAEB2;"></i>
                </a>
                <a asp-action="Planes"
                   class="sa-quick-link">
                    <i class="bi bi-card-list"></i>
                    <span>Gestionar Planes</span>
                    <i class="bi bi-chevron-right ms-auto" style="font-size:12px;color:#AEAEB2;"></i>
                </a>
                <a asp-action="Pagos"
                   class="sa-quick-link">
                    <i class="bi bi-credit-card"></i>
                    <span>Ver Pagos</span>
                    <i class="bi bi-chevron-right ms-auto" style="font-size:12px;color:#AEAEB2;"></i>
                </a>
            </div>

        </div>
    </div>

    <!-- Últimos talleres creados -->
    <div class="sa-card" style="flex:1;min-width:0;">
        <div class="sa-card-header">
            <div class="sa-card-title">Últimos Talleres Registrados</div>
            <a asp-action="Tenants" class="sa-card-link">Ver todos →</a>
        </div>
        <div class="table-responsive">
            <table class="table-custom" style="font-size:13px;">
                <thead>
                    <tr>
                        <th>Taller</th>
                        <th class="d-none d-md-table-cell">Plan</th>
                        <th class="d-none d-lg-table-cell">Precio</th>
                        <th class="d-none d-md-table-cell">Alta</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Tenants)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div style="width:34px;height:34px;border-radius:8px;background:#EBF4FF;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;color:#0066CC;flex-shrink:0;">
                                        @t.Nombre.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div style="font-weight:600;color:#1D1D1F;">@t.Nombre</div>
                                        <div style="font-size:11px;color:#6E6E73;">@t.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if (!string.IsNullOrEmpty(t.PlanNombre))
                                {
                                    var planColor = t.PlanNombre.Contains("Bás") ? "#0066CC"
                                                  : t.PlanNombre.Contains("Pro") ? "#34C759"
                                                  : "#FF9500";
                                    <span style="background:@planColor;color:#fff;padding:2px 9px;border-radius:12px;font-size:11px;font-weight:600;">
                                        @t.PlanNombre
                                    </span>
                                }
                                else
                                {
                                    <span style="background:#F5F5F7;color:#6E6E73;padding:2px 9px;border-radius:12px;font-size:11px;">Sin plan</span>
                                }
                            </td>
                            <td class="d-none d-lg-table-cell" style="color:#6E6E73;font-size:12px;">
                                $@t.PrecioPlan.ToString("N0")/mes
                            </td>
                            <td class="d-none d-md-table-cell" style="color:#6E6E73;font-size:12px;">
                                @t.FechaAlta.ToString("dd/MM/yy")
                            </td>
                            <td>
                                <span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;
                                             background:@(t.Activo ? "#E9F7EF" : "#FEF0F0");
                                             color:@(t.Activo ? "#1A7A3F" : "#CC2200");">
                                    @(t.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>
                                <form asp-action="ToggleActivo" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button type="submit"
                                            class="btn btn-sm @(t.Activo ? "btn-outline-danger" : "btn-outline-success")"
                                            style="font-size:11px;padding:3px 9px;">
                                        @(t.Activo ? "Suspender" : "Activar")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Tenants.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:#6E6E73;">
                                <i class="bi bi-buildings" style="font-size:40px;opacity:.2;display:block;margin-bottom:10px;"></i>
                                No hay talleres registrados aún.
                                <a asp-action="NuevoTenant" style="display:block;margin-top:10px;">
                                    Registrar el primero →
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- ═══ Scoped Styles ══════════════════════════════════════════════════ -->
<style>
/* Header */
.sa-page-header {
    display:flex;align-items:flex-start;justify-content:space-between;
    margin-bottom:28px;flex-wrap:wrap;gap:12px;
}
.sa-eyebrow {
    display:inline-flex;align-items:center;gap:6px;
    font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;
    color:#0066CC;background:#EBF4FF;padding:4px 10px;border-radius:20px;margin-bottom:6px;
}
.sa-title   { font-size:22px;font-weight:800;letter-spacing:-.04em;color:#1D1D1F;margin:0; }
.sa-subtitle{ font-size:13px;color:#6E6E73;margin:4px 0 0; }
.sa-header-actions{display:flex;gap:8px;flex-wrap:wrap;}

/* KPI Grid */
.sa-kpi-grid {
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:14px;
    margin-bottom:20px;
}
@@media(max-width:1100px){.sa-kpi-grid{grid-template-columns:repeat(2,1fr);}}
@@media(max-width:600px) {.sa-kpi-grid{grid-template-columns:1fr;}}

.sa-kpi {
    background:#fff;border:1px solid #D2D2D7;border-radius:16px;
    padding:18px 18px 16px;display:flex;align-items:center;gap:14px;
    transition:transform .22s,box-shadow .22s,border-color .22s;
    box-shadow:0 2px 8px rgba(0,0,0,.04);color:#1D1D1F;
}
.sa-kpi:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.09);border-color:#B0B0B8;}

.sa-kpi-icon {
    width:48px;height:48px;border-radius:12px;flex-shrink:0;
    background:var(--c);color:var(--ic);
    display:flex;align-items:center;justify-content:center;font-size:20px;
}
.sa-kpi-body{flex:1;min-width:0;}
.sa-kpi-value{font-size:24px;font-weight:800;letter-spacing:-.035em;line-height:1;color:#1D1D1F;}
.sa-kpi-label{font-size:12px;font-weight:600;color:#3A3A3C;margin-top:5px;}
.sa-kpi-sub  {font-size:11px;color:#6E6E73;margin-top:2px;}
.sa-kpi-arrow{color:#AEAEB2;font-size:13px;transition:color .2s;}
.sa-kpi:hover .sa-kpi-arrow{color:#0066CC;}

/* Bottom grid */
.sa-bottom-grid{display:grid;grid-template-columns:300px 1fr;gap:16px;}
@@media(max-width:900px){.sa-bottom-grid{grid-template-columns:1fr;}}

/* Cards */
.sa-card{background:#fff;border:1px solid #D2D2D7;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04);}
.sa-card-header{display:flex;align-items:center;justify-content:space-between;padding:18px 20px 12px;border-bottom:1px solid #F2F2F7;}
.sa-card-title{font-size:14px;font-weight:700;color:#1D1D1F;letter-spacing:-.02em;}
.sa-card-link{font-size:12px;color:#0066CC;text-decoration:none;}
.sa-card-link:hover{text-decoration:underline;}
.sa-card-body{padding:18px 20px 22px;}

/* Metric bars */
.sa-metric-row{display:flex;justify-content:space-between;margin-bottom:8px;}
.sa-metric-label{font-size:13px;color:#6E6E73;}
.sa-metric-value{font-size:13px;font-weight:700;}
.sa-bar-track{height:5px;border-radius:3px;background:#F2F2F7;overflow:hidden;}
.sa-bar-fill {height:100%;border-radius:3px;transition:width .6s ease;}

/* Quick links */
.sa-quick-link {
    display:flex;align-items:center;gap:10px;
    padding:10px 12px;border-radius:10px;border:1px solid #E8E8ED;
    background:#F5F5F7;text-decoration:none;color:#1D1D1F;
    font-size:13px;font-weight:500;transition:background .2s,border-color .2s;
}
.sa-quick-link:hover{background:#fff;border-color:#D2D2D7;color:#0066CC;}
.sa-quick-link i:first-child{color:#6E6E73;font-size:15px;width:18px;text-align:center;}
</style>
