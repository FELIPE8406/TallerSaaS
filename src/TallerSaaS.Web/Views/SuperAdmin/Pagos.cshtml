@{
    ViewData["Title"] = "Pagos Globales";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Recaudación Global</h1>
            <p class="text-muted">Monitoreo de suscripciones y facturación del SaaS.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary px-3 shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-download me-2"></i>Reporte Mensual
            </button>
            <button class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-plus-lg me-2"></i>Registrar Pago Manual
            </button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 16px; border-left: 5px solid #007AFF !important;">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold small">Recaudo Mes (COP)</h6>
                    <h3 class="fw-bold mb-0">$12.450.000</h3>
                    <span class="text-success small fw-medium"><i class="bi bi-graph-up-arrow me-1"></i>+15% vs mes anterior</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 16px; border-left: 5px solid #FF9500 !important;">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold small">Pagos Pendientes</h6>
                    <h3 class="fw-bold mb-0">8 Talleres</h3>
                    <span class="text-warning small fw-medium"><i class="bi bi-clock me-1"></i>Requieren seguimiento</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 16px; border-left: 5px solid #34C759 !important;">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold small">Tasa de Renovación</h6>
                    <h3 class="fw-bold mb-0">94%</h3>
                    <span class="text-success small fw-medium"><i class="bi bi-people me-1"></i>Clientes fidelizados</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden; border: 1px solid #D2D2D7 !important;">
        <div class="card-header bg-white border-0 p-4">
            <h5 class="fw-bold text-dark m-0">Historial de Transacciones</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 border-0">Taller / Cliente</th>
                        <th class="border-0">Plan</th>
                        <th class="border-0">Fecha</th>
                        <th class="border-0">Monto (COP)</th>
                        <th class="border-0 text-center">Estado</th>
                        <th class="pe-4 border-0 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">Taller Los Andes</div>
                            <small class="text-muted">NIT: 900.123.456-1</small>
                        </td>
                        <td><span class="badge bg-primary-subtle text-primary">Profesional</span></td>
                        <td>20 Feb 2026</td>
                        <td class="fw-semibold">$79.900</td>
                        <td class="text-center"><span class="badge bg-success-subtle text-success px-3">Completado</span></td>
                        <td class="pe-4 text-end">
                            <button class="btn btn-sm btn-light border" title="Ver Recibo"><i class="bi bi-receipt"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">Mecánica Central</div>
                            <small class="text-muted">NIT: 830.456.789-2</small>
                        </td>
                        <td><span class="badge bg-light text-dark">Básico</span></td>
                        <td>18 Feb 2026</td>
                        <td class="fw-semibold">$39.900</td>
                        <td class="text-center"><span class="badge bg-warning-subtle text-warning px-3">Pendiente</span></td>
                        <td class="pe-4 text-end">
                            <button class="btn btn-sm btn-light border" title="Notificar Pago"><i class="bi bi-envelope"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>