@{
    ViewData["Title"] = "Planes de Suscripción";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Planes de Suscripción</h1>
            <p class="text-muted">Gestiona las ofertas mensuales para los talleres en Colombia.</p>
        </div>
        <button class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px;">
            <i class="bi bi-plus-lg me-2"></i>Crear Nuevo Plan
        </button>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; border: 1px solid #D2D2D7 !important;">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <span class="badge bg-light text-primary px-3 py-2 mb-2" style="border-radius: 8px;">Esencial</span>
                        <h4 class="fw-bold text-dark">Plan Básico</h4>
                    </div>
                    <h2 class="fw-bold text-dark mb-4">$39.900<span class="fs-6 fw-normal text-muted"> /mes</span></h2>
                    <ul class="list-unstyled mb-5">
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Hasta 2 mecánicos</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Órdenes de Servicio ilimitadas</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Gestión básica de Clientes</li>
                        <li class="text-muted"><i class="bi bi-x-circle me-2"></i> Reportes avanzados Excel</li>
                    </ul>
                    <button class="btn btn-outline-primary w-100 py-2" style="border-radius: 12px;">Editar Plan</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-primary shadow" style="border-radius: 20px; border-width: 2px !important;">
                <div class="card-body p-4 position-relative">
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary px-3 py-2">MÁS POPULAR</span>
                    <div class="mb-4 mt-2">
                        <span class="badge bg-primary-subtle text-primary px-3 py-2 mb-2" style="border-radius: 8px;">Crecimiento</span>
                        <h4 class="fw-bold text-dark">Plan Profesional</h4>
                    </div>
                    <h2 class="fw-bold text-dark mb-4">$79.900<span class="fs-6 fw-normal text-muted"> /mes</span></h2>
                    <ul class="list-unstyled mb-5">
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Hasta 10 mecánicos</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Inventario de repuestos</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Reportes Excel (Clientes/Ventas)</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Soporte Prioritario</li>
                    </ul>
                    <button class="btn btn-primary w-100 py-2" style="border-radius: 12px;">Editar Plan</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; border: 1px solid #D2D2D7 !important;">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <span class="badge bg-light text-dark px-3 py-2 mb-2" style="border-radius: 8px;">Total</span>
                        <h4 class="fw-bold text-dark">Plan Enterprise</h4>
                    </div>
                    <h2 class="fw-bold text-dark mb-4">$149.900<span class="fs-6 fw-normal text-muted"> /mes</span></h2>
                    <ul class="list-unstyled mb-5">
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Mecánicos ilimitados</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Multi-sede (Próximamente)</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> Personalización de Logo</li>
                        <li class="mb-3"><i class="bi bi-check-circle-fill text-primary me-2"></i> API para Facturación</li>
                    </ul>
                    <button class="btn btn-outline-dark w-100 py-2" style="border-radius: 12px;">Editar Plan</button>
                </div>
            </div>
        </div>
    </div>
</div>