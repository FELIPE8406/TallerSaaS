@using System
@model List<TallerSaaS.Domain.Entities.PlanSuscripcion>
@{
    ViewData["Title"] = "Planes de Suscripción | GEARDASH";
    Layout = null; // Pantalla completa premium
}
<!DOCTYPE html>
<html lang="es" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Planes - GEARDASH</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #050505; color: white; }
        .neon-border { border: 1px solid rgba(0, 255, 65, 0.2); transition: all 0.3s ease; }
        .neon-border:hover { border-color: #00ff41; box-shadow: 0 0 20px rgba(0, 255, 65, 0.2); transform: translateY(-10px); }
        .bg-glass { background: rgba(15, 15, 15, 0.8); backdrop-filter: blur(10px); }
        .btn-neon { background: #00ff41; color: black; font-weight: 900; letter-spacing: 0.1em; transition: all 0.3s ease; }
        .btn-neon:hover { box-shadow: 0 0 30px #00ff41; transform: scale(1.05); }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-6 bg-[radial-gradient(circle_at_center,_#111_0%,_#050505_100%)]">
    
    <div class="mb-12 text-center animate-fade-in">
        <h1 class="text-5xl font-black italic uppercase tracking-tighter">GEAR<span class="text-[#00ff41]">DASH</span></h1>
        <p class="text-gray-400 mt-4 uppercase tracking-[0.4em] text-xs font-bold">Selecciona tu nivel de potencia</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl w-full">
        @foreach (var plan in Model)
        {
            <div class="bg-glass rounded-[2.5rem] p-10 neon-border flex flex-col h-full items-center text-center">
                <div class="w-16 h-16 rounded-2xl bg-[#00ff41]/10 flex items-center justify-center mb-6">
                    <i class="bi bi-speedometer2 text-[#00ff41] text-3xl"></i>
                </div>
                <h2 class="text-2xl font-black uppercase italic mb-2">@plan.Nombre</h2>
                <div class="text-4xl font-black text-[#00ff41] mb-6">
                    $@plan.Precio.ToString("N0")<span class="text-xs text-gray-500 font-bold">/MES</span>
                </div>
                
                <ul class="text-gray-400 text-sm space-y-4 mb-10 flex-grow">
                    <li class="flex items-center gap-2"><i class="bi bi-check2 text-[#00ff41]"></i> Hasta @plan.LimiteUsuarios usuarios</li>
                    @if (!string.IsNullOrEmpty(plan.Beneficios))
                    {
                        foreach (var b in plan.Beneficios.Split(','))
                        {
                            <li class="flex items-center gap-2"><i class="bi bi-check2 text-[#00ff41]"></i> @b.Trim()</li>
                        }
                    }
                </ul>

                <form asp-action="SelectPlan" method="post" class="w-full no-spa">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="planId" value="@plan.Id" />
                    <button type="submit" class="btn-neon w-full py-4 rounded-2xl uppercase text-xs italic">
                        Activar @plan.Nombre
                    </button>
                </form>
            </div>
        }
    </div>

    <div class="mt-16 text-gray-600 text-[10px] uppercase font-bold tracking-widest opacity-50">
        GEARDASH SYSTEMS &copy; @DateTime.Now.Year - TODOS LOS MOTORES LISTOS
    </div>

</body>
</html>
