@using TallerSaaS.Application.DTOs
@model InventarioDto
@{ ViewData["Title"] = "Editar Producto"; }

<div class="page-header">
  <div>
    <h1 class="page-title">Editar Producto</h1>
    <p class="page-subtitle">Actualiza los datos del producto en el inventario</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card-custom" style="max-width:720px;">
  <div style="padding:28px;">
    <form asp-action="Editar" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />

      <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

      <div class="row g-3 mb-4">
        <div class="col-md-8">
          <label class="form-label">Nombre del Producto *</label>
          <input asp-for="Nombre" class="form-control" maxlength="200" required />
          <span asp-validation-for="Nombre" class="text-danger" style="font-size:12px;"></span>
        </div>
        <div class="col-md-4">
          <label class="form-label">SKU / Código</label>
          <input asp-for="SKU" class="form-control" maxlength="50" />
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label">Categoría</label>
          <select asp-for="Categoria" class="form-select">
            <option value="">Sin categoría</option>
            <option>Filtros</option>
            <option>Aceites y Lubricantes</option>
            <option>Frenos</option>
            <option>Suspensión</option>
            <option>Electricidad</option>
            <option>Motor</option>
            <option>Transmisión</option>
            <option>Servicio / Mano de Obra</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Proveedor</label>
          <input asp-for="Proveedor" class="form-control" maxlength="200" />
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
      </div>

      <hr class="section-divider" />
      <h6 style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:16px;">Precios (COP $)</h6>

      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label">Precio de Compra *</label>
          <div style="position:relative;">
            <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-weight:600;pointer-events:none;">$</span>
            <input asp-for="PrecioCompra" type="number" step="100" min="0" class="form-control" style="padding-left:24px !important;" required />
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Precio de Venta *</label>
          <div style="position:relative;">
            <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-weight:600;pointer-events:none;">$</span>
            <input asp-for="PrecioVenta" type="number" step="100" min="0" class="form-control" style="padding-left:24px !important;" required />
          </div>
        </div>
      </div>

      <hr class="section-divider" />
      <h6 style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:16px;">Control de Stock</h6>

      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label">Stock Actual *</label>
          <input asp-for="Stock" type="number" min="0" class="form-control" required />
        </div>
        <div class="col-md-6">
          <label class="form-label">Stock Mínimo *</label>
          <input asp-for="StockMinimo" type="number" min="0" class="form-control" required />
          <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">Alerta al llegar a este nivel</div>
        </div>
      </div>

      <hr class="section-divider" />
      <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
