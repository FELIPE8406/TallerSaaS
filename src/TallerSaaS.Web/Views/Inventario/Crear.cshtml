@model TallerSaaS.Application.DTOs.InventarioDto
@{ ViewData["Title"] = "Nuevo Producto"; }

<div class="page-header">
  <div>
    <h1 class="page-title">Nuevo Producto</h1>
    <p class="page-subtitle">Agrega un producto o repuesto al inventario</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="card-custom" style="max-width:720px;">
  <div style="padding:28px;">
    <form asp-action="Crear" method="post" id="productoForm">
      @Html.AntiForgeryToken()

      <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

      <!-- Row 1: Name & SKU -->
      <div class="row g-3 mb-4">
        <div class="col-md-8">
          <label class="form-label">Nombre del Producto *</label>
          <input asp-for="Nombre" class="form-control" placeholder="Ej. Filtro de aceite MANN W7020"
                 maxlength="200" required />
          <span asp-validation-for="Nombre" class="text-danger" style="font-size:12px;"></span>
        </div>
        <div class="col-md-4">
          <label class="form-label">SKU / Código</label>
          <input asp-for="SKU" class="form-control" placeholder="Ej. MAN-W7020" maxlength="50" />
        </div>
      </div>

      <!-- Row 2: Category & Supplier -->
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label">Categoría</label>
          <select asp-for="Categoria" class="form-select">
            <option value="">Sin categoría</option>
            <option>Filtros</option>
            <option>Aceites y Lubricantes</option>
            <option>Frenos</option>
            <option>Suspensión</option>
            <option>Electricidad</option>
            <option>Motor</option>
            <option>Transmisión</option>
            <option>Servicio / Mano de Obra</option>
            <option>Otro</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Proveedor</label>
          <input asp-for="Proveedor" class="form-control" placeholder="Ej. Distribuidora Automotriz S.A." maxlength="200" />
        </div>
      </div>

      <!-- Description -->
      <div class="mb-4">
        <label class="form-label">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control" rows="2"
          placeholder="Detalles adicionales del producto (opcional)"></textarea>
      </div>

      <hr class="section-divider" />

      <!-- Row 3: Prices (COP) -->
      <div style="margin-bottom:12px;">
        <h6 style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:16px;">
          Precios (COP $)
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label">Precio de Compra *</label>
            <div style="position:relative;">
              <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-weight:600;pointer-events:none;">$</span>
              <input asp-for="PrecioCompra" type="number" step="100" min="0" class="form-control"
                     style="padding-left:24px !important;" placeholder="0" required />
            </div>
            <span asp-validation-for="PrecioCompra" class="text-danger" style="font-size:12px;"></span>
          </div>
          <div class="col-md-6">
            <label class="form-label">Precio de Venta *</label>
            <div style="position:relative;">
              <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-weight:600;pointer-events:none;">$</span>
              <input asp-for="PrecioVenta" type="number" step="100" min="0" class="form-control"
                     style="padding-left:24px !important;" placeholder="0" required />
            </div>
            <span asp-validation-for="PrecioVenta" class="text-danger" style="font-size:12px;"></span>
          </div>
        </div>
      </div>

      <!-- Row 4: Stock -->
      <div style="margin-bottom:12px;">
        <h6 style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:16px;">
          Control de Inventario
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label">Stock Inicial *</label>
            <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" required />
            <span asp-validation-for="Stock" class="text-danger" style="font-size:12px;"></span>
          </div>
          <div class="col-md-6">
            <label class="form-label">Stock Mínimo *</label>
            <input asp-for="StockMinimo" type="number" min="0" class="form-control" placeholder="5"
                   title="Se generará una alerta cuando el stock baje de este valor" required />
            <span asp-validation-for="StockMinimo" class="text-danger" style="font-size:12px;"></span>
            <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">
              Se activará alerta de bajo stock al llegar a este nivel
            </div>
          </div>
        </div>
      </div>

      <hr class="section-divider" />

      <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-plus-circle me-1"></i>Agregar Producto
        </button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  <script>
    // Live margin calculation
    const compra = document.querySelector('[name="PrecioCompra"]');
    const venta = document.querySelector('[name="PrecioVenta"]');
    function calcMargin() {
      const c = parseFloat(compra?.value) || 0;
      const v = parseFloat(venta?.value) || 0;
      if (c > 0 && v >= c) {
        const margin = ((v - c) / c * 100).toFixed(1);
        venta.style.borderColor = 'var(--accent)';
        venta.title = `Margen: ${margin}%`;
      } else {
        venta.style.borderColor = '';
      }
    }
    compra?.addEventListener('input', calcMargin);
    venta?.addEventListener('input', calcMargin);
  </script>
}
