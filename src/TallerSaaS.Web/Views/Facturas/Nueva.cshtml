@model List<TallerSaaS.Application.DTOs.OrdenDto>
@{
    ViewData["Title"] = "Nueva Factura";
}

<div class="page-header mb-4">
    <h1 class="page-title">🧾 Nueva Factura</h1>
    <p class="text-muted">Selecciona las órdenes terminadas para incluir en esta factura.</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        <strong>Sin órdenes disponibles.</strong>
        No hay órdenes en estado <em>Terminado</em> pendientes de facturar.
        <a asp-controller="Ordenes" asp-action="Index" class="alert-link ms-2">Ver Órdenes</a>
    </div>
}
else
{
    <form asp-action="Nueva" method="post">
        @Html.AntiForgeryToken()

        <div class="card glass-card mb-4">
            <div class="card-header">
                <span class="fw-bold">Órdenes elegibles (Estado: Terminado)</span>
                <small class="text-muted ms-2">Selecciona una o más órdenes para agrupar en la factura</small>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th width="40">
                                <input type="checkbox" id="selectAll" class="form-check-input"
                                       title="Seleccionar todo">
                            </th>
                            <th>No. Orden</th>
                            <th>Cliente</th>
                            <th>Vehículo</th>
                            <th>Fecha Entrada</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr class="orden-row" data-total="@o.Total">
                                <td>
                                    <input type="checkbox" name="ordenIds" value="@o.Id"
                                           class="form-check-input orden-check"
                                           onchange="actualizarTotal()">
                                </td>
                                <td><span class="fw-bold text-primary">@o.NumeroOrden</span></td>
                                <td>@o.ClienteNombre</td>
                                <td><small>@o.VehiculoDescripcion</small></td>
                                <td><small class="text-muted">@o.FechaEntrada.ToString("dd/MM/yyyy")</small></td>
                                <td class="text-end fw-bold">$@o.Total.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card glass-card mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h5 class="mb-0">Total a Facturar: 
                            <span id="totalFactura" class="text-primary fw-bold">$0</span>
                        </h5>
                        <small class="text-muted" id="ordenesSeleccionadas">0 órdenes seleccionadas</small>
                    </div>
                    <div class="col-md-4 text-end">
                        <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancelar</a>
                        <button type="submit" class="btn btn-primary" id="btnGenerar" disabled>
                            🧾 Generar Factura
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
}

@section Scripts {
<script>
    document.getElementById('selectAll')?.addEventListener('change', function () {
        document.querySelectorAll('.orden-check').forEach(c => c.checked = this.checked);
        actualizarTotal();
    });

    function actualizarTotal() {
        const checks = document.querySelectorAll('.orden-check:checked');
        let total = 0;
        checks.forEach(c => {
            const row = c.closest('tr');
            total += parseFloat(row.dataset.total || '0');
        });
        const fmt = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 });
        document.getElementById('totalFactura').textContent = fmt.format(total);
        document.getElementById('ordenesSeleccionadas').textContent = `${checks.length} orden${checks.length !== 1 ? 'es' : ''} seleccionada${checks.length !== 1 ? 's' : ''}`;
        document.getElementById('btnGenerar').disabled = checks.length === 0;
    }
</script>
}
