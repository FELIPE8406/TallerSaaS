@model TallerSaaS.Application.DTOs.FacturaDto
@{
    ViewData["Title"] = $"Factura {Model.NumeroFactura}";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">🧾 @Model.NumeroFactura</h1>
        <p class="text-muted mb-1">Emitida el @Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")</p>
        @if (Model.EstadoEnvio == "PendienteEnvio")
        {
            <span class="badge" style="background:#fff3e0;color:#e65100;border:1px solid #e65100;font-size:12px;">
                🔶 Facturación Electrónica — Pendiente de Envío a la DIAN
            </span>
        }
        else
        {
            <span class="badge" style="background:#e8f5e9;color:#1b5e20;border:1px solid #388e3c;font-size:12px;">
                ✅ Factura Interna
            </span>
        }
    </div>
    <div class="d-flex gap-2 flex-wrap justify-content-end">
        @if (Model.EstadoEnvio == "PendienteEnvio")
        {
            <form asp-action="EnviarADian" asp-route-id="@Model.Id" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning"
                        title="Placeholder Fase 2 — redirige al Dashboard hasta que la integración DIAN esté activa">
                    📡 Enviar a DIAN
                </button>
            </form>
        }
        <button type="button" onclick="descargarArchivo('/Facturas/DescargarPdf/@Model.Id')"
           class="btn btn-danger">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="me-1">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                <polyline points="16 6 12 2 8 6"/>
                <line x1="12" y1="2" x2="12" y2="15"/>
            </svg> PDF Apple-Style
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Html.Raw(TempData["Exito"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Html.Raw(TempData["Info"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Órdenes incluidas *@
<div class="row g-3 mb-4">
    @foreach (var o in Model.Ordenes)
    {
        <div class="col-md-6">
            <div class="card glass-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-bold text-primary">@o.NumeroOrden</span>
                        <span class="badge badge-facturada">🔒 Facturada</span>
                    </div>
                    <p class="mb-1"><strong>@o.ClienteNombre</strong></p>
                    <p class="mb-1 text-muted small">@o.VehiculoDescripcion</p>
                    <hr class="my-2">
                    @foreach (var item in o.Items)
                    {
                        <div class="d-flex justify-content-between small">
                            <span>@item.Descripcion × @item.Cantidad</span>
                            <span>$@((item.Cantidad * item.PrecioUnitario).ToString("N0"))</span>
                        </div>
                    }
                    <div class="text-end fw-bold mt-2">$@o.Total.ToString("N0")</div>
                </div>
            </div>
        </div>
    }
</div>

@* Totales *@
<div class="card glass-card mb-4">
    <div class="card-body">
        <div class="row justify-content-end">
            <div class="col-md-4">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted">Subtotal</td>
                        <td class="text-end">$@Model.Subtotal.ToString("N0")</td>
                    </tr>
                    @if (Model.Descuento > 0)
                    {
                        <tr>
                            <td class="text-muted">Descuento</td>
                            <td class="text-end text-success">-$@Model.Descuento.ToString("N0")</td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted">IVA (19%)</td>
                        <td class="text-end">$@Model.IVA.ToString("N0")</td>
                    </tr>
                    <tr class="border-top">
                        <td class="fw-bold fs-5">TOTAL</td>
                        <td class="text-end fw-bold fs-5 text-primary">$@Model.Total.ToString("N0")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

@* Condiciones del documento *@
<div class="card glass-card">
    <div class="card-body d-flex align-items-center gap-3">
        <span class="fs-3">📋</span>
        <div>
            <strong>Condiciones</strong>
            <p class="mb-0 text-muted small">
                Este documento es válido como comprobante de servicio.
                Conserve esta factura para cualquier reclamación futura.
            </p>
        </div>
        <div class="ms-auto text-end">
            <small class="text-muted d-block">Generado</small>
            <code class="small">@Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")</code>
        </div>
    </div>
</div>

