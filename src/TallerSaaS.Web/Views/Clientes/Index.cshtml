@using TallerSaaS.Application.DTOs
@using TallerSaaS.Shared.Helpers
@model PaginacionResultado<ClienteDto>
@{ ViewData["Title"] = "Clientes"; }

<div class="page-header">
  <div>
    <h1 class="page-title"><i class="bi bi-people-fill me-2" style="color:var(--primary);"></i>Clientes</h1>
    <p class="page-subtitle">@ViewBag.Total clientes registrados</p>
  </div>
  <div class="d-flex gap-2">
    <a asp-controller="Reportes" asp-action="ClientesExcel" class="btn btn-outline-secondary no-spa">
      <i class="bi bi-file-earmark-excel me-1"></i>Exportar
    </a>
    <a asp-controller="Clientes" asp-action="Crear" class="btn btn-primary">
      <i class="bi bi-plus-lg me-1"></i>Nuevo Cliente
    </a>
  </div>
</div>

<!-- Search -->
<div class="card-custom p-3 mb-4">
  <form method="get" class="d-flex gap-2">
    <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control" placeholder="Buscar por nombre, email o telefono..." />
    <button type="submit" class="btn btn-primary px-4">
      <i class="bi bi-search"></i>
    </button>
    @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
    {
      <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
    }
  </form>
</div>

<!-- Table -->
<div class="card-custom">
  <div class="table-responsive">
    <table class="table-custom">
      <thead>
        <tr>
          <th>Cliente</th>
          <th class="d-none d-md-table-cell">Email</th>
          <th class="d-none d-md-table-cell">Telefono</th>
          <th>Vehiculos</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var c in Model.Items)
        {
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:36px;height:36px;border-radius:8px;background:var(--primary);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;flex-shrink:0;">
                  @(c.NombreCompleto.Length > 0 ? c.NombreCompleto[0].ToString().ToUpper() : "?")
                </div>
                <div>
                  <div style="font-weight:600;">@c.NombreCompleto</div>
                  <div style="font-size:12px;color:var(--text-muted);">@c.Cedula</div>
                </div>
              </div>
            </td>
            <td class="d-none d-md-table-cell" style="color:var(--text-muted);">@c.Email</td>
            <td class="d-none d-md-table-cell" style="color:var(--text-muted);">@c.Telefono</td>
            <td><span class="badge bg-primary">@c.TotalVehiculos</span></td>
            <td>
              <form asp-action="ToggleStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@c.Id" />
                <button type="submit" class="badge @(c.Activo ? "bg-success" : "bg-secondary") border-0" 
                        title="Click para @(c.Activo ? "Desactivar" : "Activar")" style="cursor:pointer">
                  @(c.Activo ? "Activo" : "Inactivo")
                </button>
              </form>
            </td>
            <td>
              <div class="d-flex gap-1">
                <a asp-action="Editar" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">
                  <i class="bi bi-pencil"></i>
                </a>
                <form asp-action="Eliminar" method="post" onsubmit="event.preventDefault(); confirmarEliminar(this, '@c.NombreCompleto')">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@c.Id" />
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
        }
        @if (!Model.Items.Any())
        {
          <tr><td colspan="6" class="text-center py-5" style="color:var(--text-muted);">
            <i class="bi bi-people" style="font-size: 48px; opacity: 0.3; display: block; margin-bottom: 12px;"></i>
            No se encontraron clientes.
          </td></tr>
        }
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  @if (Model.TotalPaginas > 1)
  {
    <div class="p-3 d-flex justify-content-between align-items-center" style="border-top:1px solid var(--border);">
      <span style="font-size:13px;color:var(--text-muted);">
        Pagina @Model.Pagina de @Model.TotalPaginas (@Model.TotalRegistros registros)
      </span>
      <div class="d-flex gap-1">
        @if (Model.TienePaginaAnterior)
        {
          <a asp-action="Index" asp-route-pagina="@(Model.Pagina-1)" asp-route-buscar="@ViewBag.Buscar"
             class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-left"></i></a>
        }
        @if (Model.TienePaginaSiguiente)
        {
          <a asp-action="Index" asp-route-pagina="@(Model.Pagina+1)" asp-route-buscar="@ViewBag.Buscar"
             class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-right"></i></a>
        }
      </div>
    </div>
  }
</div>
