@model TallerSaaS.Application.DTOs.ClienteDto
@{
  ViewData["Title"] = "Nuevo Cliente";
  bool esEdicion = Model.Id != Guid.Empty;
  string titulo = esEdicion ? "Editar Cliente" : "Nuevo Cliente";
  string subtitulo = esEdicion ? "Modifica los datos del cliente" : "Registra un nuevo cliente en el sistema";
}

<div class="page-header">
  <div>
    <h1 class="page-title">@titulo</h1>
    <p class="page-subtitle">@subtitulo</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="card-custom" style="max-width:680px;">
  <div style="padding:28px;">
    <form asp-action="@(esEdicion ? "Editar" : "Crear")" method="post" id="clienteForm">
      @Html.AntiForgeryToken()
      @if (esEdicion) { <input type="hidden" asp-for="Id" /> }

      <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="display:none;"></div>

      <div class="mb-4">
        <label class="form-label">Nombre Completo *</label>
        <input asp-for="NombreCompleto" class="form-control" placeholder="Ej. Juan Camilo Rodríguez Pérez"
               maxlength="300" required />
        <span asp-validation-for="NombreCompleto" class="text-danger" style="font-size:12px;"></span>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label">Cédula / NIT</label>
          <input asp-for="Cedula" class="form-control" placeholder="Ej. 1020304050 o 900123456-1" maxlength="20" />
          <span asp-validation-for="Cedula" class="text-danger" style="font-size:12px;"></span>
        </div>
        <div class="col-md-6">
          <label class="form-label">Teléfono</label>
          <input asp-for="Telefono" class="form-control" placeholder="Ej. 3001234567" maxlength="20" />
          <span asp-validation-for="Telefono" class="text-danger" style="font-size:12px;"></span>
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label">Correo Electrónico</label>
        <input asp-for="Email" type="email" class="form-control" placeholder="correo@ejemplo.com" maxlength="200" />
        <span asp-validation-for="Email" class="text-danger" style="font-size:12px;"></span>
      </div>

      <div class="mb-4">
        <label class="form-label">Dirección</label>
        <input asp-for="Direccion" class="form-control" placeholder="Cra. 10 # 25-30, Bogotá" maxlength="300" />
        <span asp-validation-for="Direccion" class="text-danger" style="font-size:12px;"></span>
      </div>

      @if (esEdicion)
      {
        <div class="mb-4">
          <div class="form-check form-switch p-0 d-flex align-items-center gap-3">
             <input asp-for="Activo" class="form-check-input ms-0 shadow-none" type="checkbox" role="switch" id="switchActivo" style="width: 40px; height: 20px; cursor: pointer;">
             <label class="form-check-label fw-bold mb-0" for="switchActivo" style="cursor: pointer;">Cliente Activo</label>
          </div>
          <small class="text-muted">Si se desactiva, el cliente no aparecerá en las búsquedas de nuevas órdenes.</small>
        </div>
      }

      <hr class="section-divider" />

      <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-lg me-1"></i>@(esEdicion ? "Guardar Cambios" : "Crear Cliente")
        </button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
