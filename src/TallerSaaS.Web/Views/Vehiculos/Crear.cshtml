@using TallerSaaS.Application.DTOs
@model VehiculoDto
@{
  ViewData["Title"] = "Nuevo Vehículo";
  bool esEdicion = Model.Id != Guid.Empty;
  var clientes = ViewBag.Clientes as List<ClienteDto> ?? new();
}

<div class="page-header">
  <div>
    <h1 class="page-title">@(esEdicion ? "Editar Vehículo" : "Nuevo Vehículo")</h1>
    <p class="page-subtitle">@(esEdicion ? "Modifica los datos del vehículo" : "Registra un vehículo para un cliente")</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card-custom" style="max-width:720px;">
  <div style="padding:28px;">
    <form asp-action="@(esEdicion ? "Editar" : "Crear")" method="post">
      @Html.AntiForgeryToken()
      @if (esEdicion) { <input type="hidden" asp-for="Id" /> }

      <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

      <!-- Cliente -->
      <div class="mb-4">
        <label class="form-label">Cliente Propietario *</label>
        <input type="text" class="form-control" id="clienteSearch" placeholder="Buscar cliente por nombre o cédula..." 
               data-search-url="/Clientes/BuscarJson" data-target-id="ClienteId" required />
        <input type="hidden" asp-for="ClienteId" />
        <span asp-validation-for="ClienteId" class="text-danger" style="font-size:12px;"></span>
        <small class="text-muted">Empieza a escribir el nombre del cliente para seleccionarlo.</small>
      </div>

      <hr class="section-divider" />

      <!-- Marca / Modelo / Año -->
      <div class="row g-3 mb-4">
        <div class="col-md-5">
          <label class="form-label">Marca *</label>
          <input asp-for="Marca" class="form-control" placeholder="Ej. Chevrolet" maxlength="100" required />
          <span asp-validation-for="Marca" class="text-danger" style="font-size:12px;"></span>
        </div>
        <div class="col-md-5">
          <label class="form-label">Modelo *</label>
          <input asp-for="Modelo" class="form-control" placeholder="Ej. Spark GT" maxlength="100" required />
          <span asp-validation-for="Modelo" class="text-danger" style="font-size:12px;"></span>
        </div>
        <div class="col-md-2">
          <label class="form-label">Año *</label>
          <input asp-for="Anio" type="number" class="form-control" min="1960" max="@(DateTime.Now.Year + 1)" required />
          <span asp-validation-for="Anio" class="text-danger" style="font-size:12px;"></span>
        </div>
      </div>

      <!-- Placa / Color -->
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <label class="form-label">Placa</label>
          <input asp-for="Placa" class="form-control" placeholder="Ej. ABC-123" maxlength="20"
                 style="text-transform:uppercase;" />
        </div>
        <div class="col-md-4">
          <label class="form-label">Color</label>
          <input asp-for="Color" class="form-control" placeholder="Ej. Blanco" maxlength="50" />
        </div>
        <div class="col-md-4">
          <label class="form-label">Kilometraje</label>
          <input asp-for="Kilometraje" class="form-control" placeholder="Ej. 45000 km" maxlength="20" />
        </div>
      </div>

      <!-- VIN -->
      <div class="mb-4">
        <label class="form-label">VIN / No. Motor</label>
        <input asp-for="VIN" class="form-control" placeholder="Número de chasis o motor (opcional)" maxlength="50"
               style="font-family:monospace;letter-spacing:.04em;" />
      </div>

      <hr class="section-divider" />

      <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-lg me-1"></i>@(esEdicion ? "Guardar Cambios" : "Registrar Vehículo")
        </button>
      </div>
    </form>
  </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
