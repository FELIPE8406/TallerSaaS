@using TallerSaaS.Application.DTOs
@model List<OrdenDto>
@{ ViewData["Title"] = "Ordenes de Trabajo"; }

<div class="page-header">
  <div>
    <h1 class="page-title"><i class="bi bi-file-earmark-text-fill me-2" style="color:var(--primary);"></i>Ordenes</h1>
    <p class="page-subtitle">@Model.Count ordenes en total</p>
  </div>
  <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Orden</a>
</div>

<!-- Estado Filter -->
<div class="d-flex flex-wrap gap-2 mb-4">
  <a asp-action="Index" class="btn btn-sm @(ViewBag.EstadoFiltro == null ? "btn-primary" : "btn-outline-secondary")">Todas</a>
  <a asp-action="Index" asp-route-estado="1" class="btn btn-sm @(ViewBag.EstadoFiltro?.ToString() == "1" ? "btn-primary" : "btn-outline-secondary")">
    <i class="bi bi-inbox me-1"></i>Recibidas
  </a>
  <a asp-action="Index" asp-route-estado="2" class="btn btn-sm @(ViewBag.EstadoFiltro?.ToString() == "2" ? "btn-warning" : "btn-outline-secondary")" style="color:@(ViewBag.EstadoFiltro?.ToString() == "2" ? "white" : "")">
    <i class="bi bi-wrench me-1"></i>En Reparacion
  </a>
  <a asp-action="Index" asp-route-estado="3" class="btn btn-sm @(ViewBag.EstadoFiltro?.ToString() == "3" ? "btn-success" : "btn-outline-secondary")">
    <i class="bi bi-check-circle me-1"></i>Terminadas
  </a>
  <a asp-action="Index" asp-route-estado="4" class="btn btn-sm @(ViewBag.EstadoFiltro?.ToString() == "4" ? "btn-secondary" : "btn-outline-secondary")">
    <i class="bi bi-check2-all me-1"></i>Entregadas
  </a>
</div>

<div class="card-custom">
  <div class="table-responsive">
    <table class="table-custom">
      <thead>
        <tr>
          <th>No. Orden</th>
          <th>Cliente / Vehiculo</th>
          <th class="d-none d-md-table-cell">Fecha</th>
          <th>Estado</th>
          <th class="d-none d-lg-table-cell">Total</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var o in Model)
        {
          <tr>
            <td><strong style="color:var(--primary);">@o.NumeroOrden</strong></td>
            <td>
              <div style="font-weight:600;font-size:14px;">@o.ClienteNombre</div>
              <div style="font-size:12px;color:var(--text-muted);">@o.VehiculoDescripcion</div>
            </td>
            <td class="d-none d-md-table-cell" style="color:var(--text-muted);">@o.FechaEntrada.ToString("dd/MM/yy")</td>
            <td>
              <span class="estado-badge @o.EstadoClase">
                @o.EstadoTexto
              </span>
            </td>
            <td class="d-none d-lg-table-cell"><strong>$@o.Total.ToString("N2")</strong></td>
            <td>
              <div class="d-flex gap-1">
                <a asp-action="Detalle" asp-route-id="@o.Id" class="btn btn-sm btn-primary">
                  <i class="bi bi-eye"></i>
                </a>
                <a asp-controller="Reportes" asp-action="FacturaPdf" asp-route-ordenId="@o.Id"
                   class="btn btn-sm btn-outline-secondary" title="Descargar PDF">
                  <i class="bi bi-file-earmark-pdf"></i>
                </a>
              </div>
            </td>
          </tr>
        }
        @if (!Model.Any())
        {
          <tr><td colspan="6" class="text-center py-5" style="color:var(--text-muted);">
            <i class="bi bi-file-earmark-text" style="font-size:48px;opacity:.3;display:block;margin-bottom:12px;"></i>
            No hay ordenes con este filtro.
          </td></tr>
        }
      </tbody>
    </table>
  </div>
</div>
