@{ ViewData["Title"] = "Ordenes de Trabajo"; }

<div class="page-header">
  <div>
    <h1 class="page-title"><i class="bi bi-file-earmark-text-fill me-2" style="color:var(--primary);"></i>Ordenes</h1>
    <p class="page-subtitle" id="subtitleConteo">Cargando...</p>
  </div>
  <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Orden</a>
</div>

<!-- Estado Filter -->
<div class="d-flex flex-wrap gap-2 mb-4">
  <input type="hidden" id="estadoFiltro" value="@ViewBag.EstadoFiltro" />
  <button type="button" data-val=""  class="btn btn-sm btn-filter-ordenes btn-primary">Todas</button>
  <button type="button" data-val="1" class="btn btn-sm btn-filter-ordenes btn-outline-secondary"><i class="bi bi-inbox me-1"></i>Recibidas</button>
  <button type="button" data-val="2" class="btn btn-sm btn-filter-ordenes btn-outline-secondary"><i class="bi bi-wrench me-1"></i>En Reparacion</button>
  <button type="button" data-val="3" class="btn btn-sm btn-filter-ordenes btn-outline-secondary"><i class="bi bi-check-circle me-1"></i>Terminadas</button>
  <button type="button" data-val="4" class="btn btn-sm btn-filter-ordenes btn-outline-secondary"><i class="bi bi-check2-all me-1"></i>Entregadas</button>
</div>

<div class="card-custom">
  <div class="table-responsive">
    <table class="table-custom">
      <thead>
        <tr>
          <th>No. Orden</th>
          <th>Cliente / Vehiculo</th>
          <th class="d-none d-md-table-cell">Fecha</th>
          <th>Estado</th>
          <th class="d-none d-lg-table-cell">Total</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tbodyOrdenes">
        <tr><td colspan="6" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm me-2"></div>Cargando...</td></tr>
      </tbody>
    </table>
  </div>
  <div id="paginatorContainer"></div>
</div>

@section Scripts {
    <script src="~/js/ordenes.js" asp-append-version="true"></script>
}
