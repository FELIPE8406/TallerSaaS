@using TallerSaaS.Application.DTOs
@model TallerSaaS.Application.DTOs.OrdenDto
@section Styles {
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <style>
    /* Select2 Dark/Light Mode adaptivity */
    .select2-container--default .select2-selection--single {
        height: 42px;
        padding-top: 6px;
        border: 1px solid var(--border-subtle);
        background-color: var(--surface2);
        color: var(--text);
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
        color: var(--text);
    }
    .select2-dropdown {
        background-color: var(--surface2);
        border: 1px solid var(--border-subtle);
        color: var(--text);
        z-index: 9999 !important;
    }
    .select2-container {
        z-index: 9998 !important;
    }
    .select2-container--default .select2-results__option--highlighted[aria-selected] {
        background-color: var(--primary);
    }
  </style>
}

<div class="page-header">
  <div>
    <h1 class="page-title">Nueva Orden de Trabajo</h1>
    <p class="page-subtitle">Registra un nuevo trabajo de servicio</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<form asp-action="Crear" method="post" id="ordenForm">
  @Html.AntiForgeryToken()

  <div class="row g-4">

    <!-- LEFT: Client & Vehicle -->
    <div class="col-lg-7">
      <div class="card-custom mb-4">
        <div style="padding:20px 24px; border-bottom:1px solid var(--border-subtle);">
          <h6 style="margin:0;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);">
            Cliente y Vehículo
          </h6>
        </div>
        <div style="padding:24px;">

          <div class="mb-4 position-relative">
            <label class="form-label">Cliente *</label>
            <div class="input-group">
                <span class="input-group-text bg-surface2 border-subtle"><i class="bi bi-person"></i></span>
                <input type="text" id="clienteInput" class="form-control" autocomplete="off"
                       placeholder="Escriba nombre o identificación del cliente...">
            </div>
            <input type="hidden" id="clienteId" />
            <div id="clientesDropdown" class="ag-search-dropdown shadow border rounded mt-1 overflow-auto" 
                 style="position: absolute; top: 100%; left: 0; right: 0; background: var(--surface2); z-index: 1000; display: none; max-height: 250px;">
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label">Vehículo *</label>
            <select asp-for="VehiculoId" id="vehiculoSelect" class="form-select" style="width:100%" disabled required>
                <option value="">Seleccione primero un cliente...</option>
            </select>
            <span asp-validation-for="VehiculoId" class="text-danger" style="font-size:12px;"></span>
          </div>

          <div class="mb-3">
            <label class="form-label">Diagnóstico Inicial</label>
            <textarea asp-for="DiagnosticoInicial" class="form-control" rows="3"
              placeholder="Describe el problema reportado por el cliente..."></textarea>
          </div>

          <div>
            <label class="form-label">Observaciones</label>
            <textarea asp-for="Observaciones" class="form-control" rows="2"
              placeholder="Notas adicionales (opcional)"></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Financial & Summary -->
    <div class="col-lg-5">
      <div class="card-custom mb-4">
        <div style="padding:20px 24px; border-bottom:1px solid var(--border-subtle);">
          <h6 style="margin:0;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);">
            Financiero (COP)
          </h6>
        </div>
        <div style="padding:24px;">

          <div class="mb-3">
            <label class="form-label">Descuento ($)</label>
            <input asp-for="Descuento" type="number" step="1000" min="0" class="form-control"
                   placeholder="0" />
            <span asp-validation-for="Descuento" class="text-danger" style="font-size:12px;"></span>
          </div>

          <hr class="section-divider" />

          <div class="mb-3">
            <label class="form-label">Estado Inicial</label>
            <select asp-for="Estado" class="form-select">
              <option value="1">Recibido</option>
              <option value="2">En Reparación</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Fecha de Entrada</label>
            <input asp-for="FechaEntrada" type="datetime-local" class="form-control"
                   value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
          </div>

        </div>
      </div>

      <div class="d-grid gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-plus-circle me-2"></i>Crear Orden de Trabajo
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </div>

  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  <script>
    /**
     * TallerSaaS Select2 Robust Initializer
     * This function is designed to work both on direct load and SPA navigation.
        /**
     * TallerSaaS Optimized Search (Preload + Cache + Debounce)
     */
    let clientesCache = [];
    let clientesCargados = false;

    async function inicializarBusquedaClientes() {
        console.log("Antigravity: Initializing Optimized Search (Cache + Debounce)...");
        
        const $vehiculoSelect = $('#vehiculoSelect');
        const inputCliente = document.getElementById('clienteInput');
        const dropdown = document.getElementById('clientesDropdown');

        if ($vehiculoSelect.hasClass('select2-hidden-accessible')) {
            $vehiculoSelect.select2('destroy');
        }
        $vehiculoSelect.select2({ theme: "default", placeholder: "Seleccione primero un cliente" });

        // 1. PRELOAD
        if (!clientesCargados) {
            try {
                const response = await fetch('@Url.Action("GetAllJson", "Clientes")');
                if (response.ok) {
                    clientesCache = await response.json();
                    clientesCargados = true;
                    console.log(`Antigravity: Cache loaded with ${clientesCache.length} clients.`);
                }
            } catch (err) {
                console.error("Antigravity: Error preloading client cache.", err);
            }
        }

        // 2. DEBOUNCED INPUT
        inputCliente.addEventListener('input', debounce(function () {
            const query = this.value.trim();
            if (query.length < 2) {
                dropdown.style.display = 'none';
                return;
            }
            const resultados = filtrarClientes(query);
            renderizarResultados(resultados);
        }, 300));

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (e.target !== inputCliente && !dropdown.contains(e.target)) {
                dropdown.style.display = 'none';
            }
        });
    }

    function debounce(fn, delay) {
        let timeout;
        return function (...args) {
            clearTimeout(timeout);
            timeout = setTimeout(() => fn.apply(this, args), delay);
        };
    }

    function filtrarClientes(query) {
        const q = query.toLowerCase();
        return clientesCache.filter(c =>
            c.text.toLowerCase().includes(q)
        );
    }

    function renderizarResultados(lista) {
        const container = document.getElementById('clientesDropdown');
        container.innerHTML = '';

        if (lista.length === 0) {
            container.innerHTML = '<div class="p-3 text-muted" style="font-size:13px;">No se encontraron resultados</div>';
        } else {
            lista.slice(0, 15).forEach(c => {
                const item = document.createElement('div');
                item.className = 'p-2 border-bottom ag-search-item';
                item.style.cursor = 'pointer';
                item.style.fontSize = '14px';
                item.textContent = c.text;

                item.onclick = () => seleccionarCliente(c);
                container.appendChild(item);
            });
        }
        container.style.display = 'block';
    }

    function seleccionarCliente(cliente) {
        document.getElementById('clienteInput').value = cliente.text;
        document.getElementById('clienteId').value = cliente.id;
        document.getElementById('clientesDropdown').style.display = 'none';
        
        // Trigger original vehicle loading logic
        cargarVehiculos(cliente.id);
    }

    function cargarVehiculos(clienteId) {
        const $select = $('#vehiculoSelect');
        $select.empty().append('<option value="">Cargando vehículos...</option>').prop('disabled', true).trigger('change');

        $.getJSON(`/Vehiculos/BuscarJson?clienteId=${clienteId}`, function(data) {
            $select.empty().append('<option value="">Elija el vehículo del cliente...</option>');
            if (data && data.length > 0) {
                data.forEach(v => {
                    $select.append(new Option(v.text, v.id, false, false));
                });
                $select.prop('disabled', false);
            } else {
                $select.append('<option value="">El cliente no tiene vehículos de alta</option>');
                showErrorToast("Este cliente no tiene ningún vehículo registrado.");
            }
            $select.trigger('change');
        });
    }

    // Execution Context
    (function init() {
        if (typeof jQuery !== 'undefined' && typeof $.fn.select2 !== 'undefined') {
            inicializarBusquedaClientes();
        } else {
            let attempts = 0;
            const check = setInterval(() => {
                attempts++;
                if (typeof jQuery !== 'undefined' && typeof $.fn.select2 !== 'undefined') {
                    inicializarBusquedaClientes();
                    clearInterval(check);
                }
                if (attempts > 50) clearInterval(check);
            }, 100);
        }
    })();

    document.addEventListener('DOMContentLoaded', function () {
        if (typeof inicializarBusquedaClientes === 'function') {
            inicializarBusquedaClientes();
        }
    });
  </script>
}
