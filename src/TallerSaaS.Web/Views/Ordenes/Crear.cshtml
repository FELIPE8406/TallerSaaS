@using TallerSaaS.Application.DTOs
@model TallerSaaS.Application.DTOs.OrdenDto
@{
  ViewData["Title"] = "Nueva Orden";
  var clientes = ViewBag.Clientes as List<ClienteDto> ?? new();
  var vehiculos = ViewBag.Vehiculos as List<VehiculoDto> ?? new();
}

<div class="page-header">
  <div>
    <h1 class="page-title">Nueva Orden de Trabajo</h1>
    <p class="page-subtitle">Registra un nuevo trabajo de servicio</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<form asp-action="Crear" method="post" id="ordenForm">
  @Html.AntiForgeryToken()

  <div class="row g-4">

    <!-- LEFT: Client & Vehicle -->
    <div class="col-lg-7">
      <div class="card-custom mb-4">
        <div style="padding:20px 24px; border-bottom:1px solid var(--border-subtle);">
          <h6 style="margin:0;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);">
            Cliente y Vehículo
          </h6>
        </div>
        <div style="padding:24px;">

          <div class="mb-4">
            <label class="form-label">Cliente *</label>
            <select id="clienteSelect" class="form-select" onchange="cargarVehiculos(this.value)" required>
              <option value="">Seleccionar cliente...</option>
              @foreach (var c in clientes)
              {
                <option value="@c.Id">@c.NombreCompleto @(c.Cedula != null ? $"— {c.Cedula}" : "")</option>
              }
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label">Vehículo *</label>
            <select id="vehiculoSelect" asp-for="VehiculoId" class="form-select" required>
              <option value="">Primero seleccione un cliente...</option>
              @foreach (var v in vehiculos)
              {
                <option value="@v.Id" data-cliente="@v.ClienteId">@v.Descripcion — @v.Placa</option>
              }
            </select>
            <span asp-validation-for="VehiculoId" class="text-danger" style="font-size:12px;"></span>
          </div>

          <div class="mb-3">
            <label class="form-label">Diagnóstico Inicial</label>
            <textarea asp-for="DiagnosticoInicial" class="form-control" rows="3"
              placeholder="Describe el problema reportado por el cliente..."></textarea>
          </div>

          <div>
            <label class="form-label">Observaciones</label>
            <textarea asp-for="Observaciones" class="form-control" rows="2"
              placeholder="Notas adicionales (opcional)"></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Financial & Summary -->
    <div class="col-lg-5">
      <div class="card-custom mb-4">
        <div style="padding:20px 24px; border-bottom:1px solid var(--border-subtle);">
          <h6 style="margin:0;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);">
            Financiero (COP)
          </h6>
        </div>
        <div style="padding:24px;">

          <div class="mb-3">
            <label class="form-label">Descuento ($)</label>
            <input asp-for="Descuento" type="number" step="1000" min="0" class="form-control"
                   placeholder="0" />
            <span asp-validation-for="Descuento" class="text-danger" style="font-size:12px;"></span>
          </div>

          <hr class="section-divider" />

          <div class="mb-3">
            <label class="form-label">Estado Inicial</label>
            <select asp-for="Estado" class="form-select">
              <option value="1">Recibido</option>
              <option value="2">En Reparación</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Fecha de Entrada</label>
            <input asp-for="FechaEntrada" type="datetime-local" class="form-control"
                   value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
          </div>

        </div>
      </div>

      <div class="d-grid gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-plus-circle me-2"></i>Crear Orden de Trabajo
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </div>

  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  <script>
    const allVehicles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
      vehiculos.Select(v => new { id = v.Id, clienteId = v.ClienteId, desc = v.Descripcion, placa = v.Placa })
    ));

    function cargarVehiculos(clienteId) {
      const sel = document.getElementById('vehiculoSelect');
      sel.innerHTML = '<option value="">Seleccionar vehículo...</option>';
      if (!clienteId) return;
      const filtered = allVehicles.filter(v => v.clienteId === clienteId);
      if (filtered.length === 0) {
        sel.innerHTML = '<option value="">Sin vehículos registrados</option>';
        return;
      }
      filtered.forEach(v => {
        const opt = document.createElement('option');
        opt.value = v.id;
        opt.textContent = `${v.desc} — ${v.placa ?? 'Sin placa'}`;
        sel.appendChild(opt);
      });
    }
  </script>
}
