@using TallerSaaS.Application.DTOs
@using System.Text.Json
@model DashboardDto
@{
    ViewData["Title"] = "Dashboard";

    // KPI data from DashboardController ViewBag
    var ventasMes        = (decimal)(ViewBag.VentasMesCOP        ?? Model.VentasMes);
    var ordenesActivas   = (int)    (ViewBag.OrdenesActivas       ?? Model.OrdenesAbiertas);
    var vehiculosEntrega = (int)    (ViewBag.VehiculosParaEntrega ?? 0);
    var totalVehiculos   = (int)    (ViewBag.TotalVehiculos       ?? Model.TotalVehiculos);

    // Chart data
    var flujoCajaLabels    = ViewBag.FlujoCajaLabels   as List<string>  ?? Model.VentasMensuales.Select(v => v.Mes).ToList();
    var flujoCajaData      = ViewBag.FlujoCajaData     as List<decimal> ?? Model.VentasMensuales.Select(v => v.Total).ToList();
    var topServLabels      = ViewBag.TopServiciosLabels as List<string>  ?? Model.OrdenesPorEstado.Select(e => e.Estado).ToList();
    var topServData        = ViewBag.TopServiciosData   as List<int>     ?? Model.OrdenesPorEstado.Select(e => e.Conteo).ToList();

    var flujoCajaLabelsJson = JsonSerializer.Serialize(flujoCajaLabels);
    var flujoCajaDataJson   = JsonSerializer.Serialize(flujoCajaData);
    var topServLabelsJson   = JsonSerializer.Serialize(topServLabels);
    var topServDataJson     = JsonSerializer.Serialize(topServData);
    var estadosJson         = JsonSerializer.Serialize(Model.OrdenesPorEstado);
}

<!-- ════════════════════════════════════════════════════════════
     PAGE HEADER
════════════════════════════════════════════════════════════════ -->
<div class="dash-page-header">
    <div>
        <h1 class="dash-title">Dashboard</h1>
        <p class="dash-subtitle">
            <span class="dash-dot"></span>
            Resumen operativo · @DateTime.Now.ToString("dddd, d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-CO"))
        </p>
    </div>
    <div class="dash-header-actions">
        <!-- iOS-Style Share / Export Button -->
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-1"
                    type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <!-- iOS Share icon SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                     stroke-linejoin="round">
                    <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                    <polyline points="16 6 12 2 8 6"/>
                    <line x1="12" y1="2" x2="12" y2="15"/>
                </svg>
                Exportar
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-radius:12px;">
                <li><h6 class="dropdown-header">Reportes</h6></li>
                <li>
                    <a class="dropdown-item" href="#" onclick="event.preventDefault(); descargarArchivo('@Url.Action("DescargarExcel", "Facturas")');">
                        📊 Facturas Excel Pro
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" href="#" onclick="event.preventDefault(); descargarArchivo('@Url.Action("VentasExcel", "Reportes")');">
                        📈 Ventas Excel
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" href="#" onclick="event.preventDefault(); descargarArchivo('@Url.Action("ClientesExcel", "Reportes")');">
                        👥 Clientes Excel
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item" asp-controller="Facturas" asp-action="Index">
                        🧾 Ver Facturas
                    </a>
                </li>
            </ul>
        </div>
        <a asp-controller="Ordenes" asp-action="Crear" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nueva Orden
        </a>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════════
     4 KPI CARDS — Glassmorphism
════════════════════════════════════════════════════════════════ -->
<div class="kpi-grid">

    <!-- Ventas del Mes COP -->
    <a href="#" onclick="event.preventDefault(); descargarArchivo('@Url.Action("VentasExcel", "Reportes")');" class="kpi-glass text-decoration-none">
        <div class="kpi-glass-icon" style="--icon-bg:rgba(0,214,50,.08);--icon-color:#00d632;">
            <i class="bi bi-cash-stack"></i>
        </div>
        <div class="kpi-glass-body">
            <div class="kpi-glass-value">
                $@ventasMes.ToString("N0")
            </div>
            <div class="kpi-glass-label">Ventas del Mes (COP)</div>
            <div class="kpi-glass-sub">Órdenes pagadas · mes actual</div>
        </div>
        <div class="kpi-glass-arrow"><i class="bi bi-chevron-right"></i></div>
    </a>

    <!-- Órdenes Activas -->
    <a asp-controller="Ordenes" asp-action="Index" class="kpi-glass text-decoration-none">
        <div class="kpi-glass-icon" style="--icon-bg:rgba(255,149,0,.08);--icon-color:#FF9500;">
            <i class="bi bi-wrench-adjustable-circle"></i>
        </div>
        <div class="kpi-glass-body">
            <div class="kpi-glass-value">@ordenesActivas</div>
            <div class="kpi-glass-label">Órdenes Activas</div>
            <div class="kpi-glass-sub">En proceso de servicio</div>
        </div>
        <div class="kpi-glass-arrow"><i class="bi bi-chevron-right"></i></div>
    </a>

    <!-- Vehículos para Entrega -->
    <a asp-controller="Ordenes" asp-action="Index" asp-route-estado="3" class="kpi-glass text-decoration-none">
        <div class="kpi-glass-icon" style="--icon-bg:rgba(52,199,89,.08);--icon-color:#34C759;">
            <i class="bi bi-car-front"></i>
        </div>
        <div class="kpi-glass-body">
            <div class="kpi-glass-value">@vehiculosEntrega</div>
            <div class="kpi-glass-label">Listos para Entrega</div>
            <div class="kpi-glass-sub">Terminados · pendiente al cliente</div>
        </div>
        <div class="kpi-glass-arrow"><i class="bi bi-chevron-right"></i></div>
    </a>

    <!-- Total Vehículos -->
    <a asp-controller="Vehiculos" asp-action="Index" class="kpi-glass text-decoration-none">
        <div class="kpi-glass-icon" style="--icon-bg:rgba(108,108,255,.08);--icon-color:#6C6CFF;">
            <i class="bi bi-car-front-fill"></i>
        </div>
        <div class="kpi-glass-body">
            <div class="kpi-glass-value">@totalVehiculos</div>
            <div class="kpi-glass-label">Vehículos Registrados</div>
            <div class="kpi-glass-sub">Parque total del taller</div>
        </div>
        <div class="kpi-glass-arrow"><i class="bi bi-chevron-right"></i></div>
    </a>

</div>

<!-- ════════════════════════════════════════════════════════════
     CHARTS ROW
════════════════════════════════════════════════════════════════ -->
<div class="dash-charts-row">

    <!-- Chart A — Ingresos Semanales (line + gradient) -->
    <div class="dash-chart-card dash-chart-wide">
        <div class="dash-chart-header">
            <div>
                <div class="dash-chart-title">Flujo de Caja Semanal</div>
                <div class="dash-chart-sub">Ingresos por semana · COP</div>
            </div>
            <span class="dash-chart-badge">8 semanas</span>
        </div>
        <div class="dash-chart-body">
            <canvas id="chartIngresos"></canvas>
        </div>
    </div>

    <!-- Chart B — Servicios más solicitados (horizontal bar) -->
    <div class="dash-chart-card dash-chart-narrow">
        <div class="dash-chart-header">
            <div>
                <div class="dash-chart-title">Top Servicios</div>
                <div class="dash-chart-sub">Más solicitados</div>
            </div>
            <span class="dash-chart-badge">Top 6</span>
        </div>
        <div class="dash-chart-body">
            <canvas id="chartServicios"></canvas>
        </div>
    </div>

</div>

<!-- ════════════════════════════════════════════════════════════
     QUICK ACTIONS
════════════════════════════════════════════════════════════════ -->
<div class="dash-quick-section">
    <div class="dash-section-label">Acciones Rápidas</div>
    <div class="dash-quick-grid">

        <a asp-controller="Ordenes" asp-action="Crear" class="dash-quick-btn" data-color="#00d632">
            <div class="dash-quick-icon" style="background:#E8FCEB;color:#00d632;">
                <i class="bi bi-file-earmark-plus"></i>
            </div>
            <div>
                <div class="dash-quick-name">Nueva Orden</div>
                <div class="dash-quick-desc">Abrir servicio</div>
            </div>
        </a>

        <a asp-controller="Clientes" asp-action="Crear" class="dash-quick-btn" data-color="#34C759">
            <div class="dash-quick-icon" style="background:#E9F7EF;color:#34C759;">
                <i class="bi bi-person-plus"></i>
            </div>
            <div>
                <div class="dash-quick-name">Registrar Cliente</div>
                <div class="dash-quick-desc">Nuevo cliente</div>
            </div>
        </a>

        <a asp-controller="Vehiculos" asp-action="Crear" class="dash-quick-btn" data-color="#FF9500">
            <div class="dash-quick-icon" style="background:#FFF4E5;color:#FF9500;">
                <i class="bi bi-car-front"></i>
            </div>
            <div>
                <div class="dash-quick-name">Ingresar Vehículo</div>
                <div class="dash-quick-desc">Registrar auto</div>
            </div>
        </a>

        <a asp-controller="Inventario" asp-action="Crear" class="dash-quick-btn" data-color="#6C6CFF">
            <div class="dash-quick-icon" style="background:#EBEBFF;color:#6C6CFF;">
                <i class="bi bi-box-seam"></i>
            </div>
            <div>
                <div class="dash-quick-name">Agregar Repuesto</div>
                <div class="dash-quick-desc">Inventario</div>
            </div>
        </a>

        <a asp-controller="Facturas" asp-action="Nueva" class="dash-quick-btn" data-color="#FF9F0A">
            <div class="dash-quick-icon" style="background:#FFF5E0;color:#FF9F0A;">
                <i class="bi bi-receipt"></i>
            </div>
            <div>
                <div class="dash-quick-name">Nueva Factura</div>
                <div class="dash-quick-desc">Facturar orden</div>
            </div>
        </a>

    </div>
</div>

<!-- ════════════════════════════════════════════════════════════
     STOCK ALERTS (conditional)
════════════════════════════════════════════════════════════════ -->
@if (Model.ProductosBajoStock.Any())
{
    <div class="card-custom p-4 mt-3">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill" style="color:var(--warning);font-size:16px;"></i>
            <span style="font-weight:700;font-size:14px;color:var(--text);">Alertas de Stock Bajo</span>
            <span class="badge rounded-pill" style="background:#FFF4E5;color:#B25300;font-size:11px;">@Model.ProductosBajoStock.Count</span>
        </div>
        <div class="row g-2">
            @foreach (var p in Model.ProductosBajoStock)
            {
                <div class="col-12 col-md-6">
                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3"
                         style="background:var(--surface2);border:1px solid var(--border);">
                        <div>
                            <div style="font-weight:600;font-size:14px;">@p.Nombre</div>
                            <span class="badge bg-@p.NivelStockClase" style="font-size:11px;">
                                @p.NivelStock — @p.Stock und.
                            </span>
                        </div>
                        <a asp-controller="Inventario" asp-action="Editar" asp-route-id="@p.Id"
                           class="btn btn-sm btn-outline-secondary">Ajustar</a>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ── TempData Info/Exito alerts (from EnviarADian redirect, etc.) ──────── *@
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show mt-3" role="alert">
        @Html.Raw(TempData["Info"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @Html.Raw(TempData["Exito"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Widget: Facturas Electrónicas Pendientes de Envío a la DIAN ───────── *@
@if (Model.FacturasPendientesDian > 0)
{
    <div class="card-custom p-4 mt-3"
         style="border-left: 4px solid #e65100; background: #fff8f0;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
                <div style="width:44px;height:44px;border-radius:12px;background:#fff3e0;
                            display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:22px;">
                    📡
                </div>
                <div>
                    <div style="font-weight:700;font-size:15px;color:#1D1D1F;">
                        Facturas Pendientes de Envío a la DIAN
                    </div>
                    <div style="font-size:13px;color:#6E6E73;">
                        <strong style="color:#e65100;">@Model.FacturasPendientesDian</strong>
                        factura@(Model.FacturasPendientesDian != 1 ? "s" : "") electrónica@(Model.FacturasPendientesDian != 1 ? "s" : "")
                        en estado <em>Pendiente de Envío</em>.
                        Usa el botón <strong>"Enviar a DIAN"</strong> desde el detalle de cada factura.
                    </div>
                </div>
            </div>
            <a asp-controller="Facturas" asp-action="Index"
               class="btn btn-sm"
               style="background:#e65100;color:#fff;border-radius:10px;padding:8px 18px;font-weight:600;">
                Ver Facturas
            </a>
        </div>
    </div>
}

<!-- ════════════════════════════════════════════════════════════
     DASHBOARD-SCOPED STYLES
════════════════════════════════════════════════════════════════ -->
<style>
/* ── Page Header ── */
.dash-page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 12px;
}
.dash-title {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #1D1D1F;
    margin: 0;
}
.dash-subtitle {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #6E6E73;
    font-size: 13px;
    margin: 4px 0 0;
}
.dash-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #34C759;
    display: inline-block;
    animation: pulse 2s infinite;
}
@@keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%       { opacity:.5; transform:scale(1.35); }
}
.dash-header-actions { display:flex;gap:8px;flex-wrap:wrap; }

/* ── KPI Grid ── */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 20px;
}
@@media (max-width: 1100px) { .kpi-grid { grid-template-columns: repeat(2,1fr); } }
@@media (max-width: 600px)  { .kpi-grid { grid-template-columns: 1fr; } }

/* ── Glassmorphism KPI Card ── */
.kpi-glass {
    background: #FFFFFF;
    border: 1px solid #D2D2D7;
    border-radius: 16px;
    padding: 20px 20px 18px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
    position: relative;
    overflow: hidden;
    color: #1D1D1F;
}
.kpi-glass::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.9) 0%, rgba(245,245,247,.6) 100%);
    pointer-events: none;
}
.kpi-glass:hover {
    transform: translateY(-3px);
    border-color: #B0B0B8;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
}
.kpi-glass-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--icon-bg);
    color: var(--icon-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
}
.kpi-glass-body {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
}
.kpi-glass-value {
    font-size: 26px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.035em;
    color: #1D1D1F;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.kpi-glass-label {
    font-size: 12px;
    font-weight: 600;
    color: #3A3A3C;
    margin-top: 5px;
}
.kpi-glass-sub {
    font-size: 11px;
    color: #6E6E73;
    margin-top: 2px;
}
.kpi-glass-arrow {
    color: #AEAEB2;
    font-size: 14px;
    position: relative;
    z-index: 1;
    transition: color .2s;
}
.kpi-glass:hover .kpi-glass-arrow { color: #00d632; }

/* ── Glass Card (generic, used in Facturas / Timeline views) ── */
.glass-card {
    background: rgba(255,255,255,0.82);
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.7);
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}

/* ── Badge: Facturada ── */
.badge-facturada {
    background-color: #5856D6;
    color: #fff;
    font-size: 11px;
    padding: 4px 8px;
    border-radius: 6px;
}

/* ── Charts Row ── */
.dash-charts-row {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 16px;
    margin-bottom: 20px;
}
@@media (max-width: 1100px) { .dash-charts-row { grid-template-columns: 1fr; } }

.dash-chart-card {
    background: #FFFFFF;
    border: 1px solid #D2D2D7;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}
.dash-chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 22px 12px;
    border-bottom: 1px solid #F2F2F7;
}
.dash-chart-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1D1D1F;
}
.dash-chart-sub {
    font-size: 12px;
    color: #6E6E73;
    margin-top: 2px;
}
.dash-chart-badge {
    background: #F5F5F7;
    border: 1px solid #E8E8ED;
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    color: #6E6E73;
    white-space: nowrap;
}
.dash-chart-body {
    padding: 16px 20px 20px;
    height: 260px;
    position: relative;
}
.dash-chart-body canvas { width:100% !important; height:100% !important; }

/* ── Quick Actions ── */
.dash-quick-section {
    background: #FFFFFF;
    border: 1px solid #D2D2D7;
    border-radius: 16px;
    padding: 20px 22px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
    margin-bottom: 20px;
}
.dash-section-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #6E6E73;
    margin-bottom: 14px;
}
.dash-quick-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}
.dash-quick-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 18px;
    border-radius: 12px;
    border: 1.5px solid #E8E8ED;
    background: #F5F5F7;
    text-decoration: none;
    color: #1D1D1F;
    transition: border-color .2s, background .2s, transform .2s;
    min-width: 190px;
    flex: 1;
}
.dash-quick-btn:hover {
    background: #fff;
    border-color: attr(data-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,.06);
}
.dash-quick-btn:hover .dash-quick-name { color: #00d632; }
.dash-quick-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    flex-shrink: 0;
}
.dash-quick-name {
    font-size: 13px;
    font-weight: 600;
    transition: color .2s;
}
.dash-quick-desc {
    font-size: 11px;
    color: #6E6E73;
    margin-top: 1px;
}
</style>

<script>
  window._dashData = {
    flujoCajaLabels: @Html.Raw(flujoCajaLabelsJson),
    flujoCajaData: @Html.Raw(flujoCajaDataJson),
    topServLabels: @Html.Raw(topServLabelsJson),
    topServData: @Html.Raw(topServDataJson)
  };
</script>
@section Scripts {
    <script src="/js/dashboard.js"></script>
}
