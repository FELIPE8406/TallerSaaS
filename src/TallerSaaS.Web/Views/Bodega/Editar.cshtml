@model TallerSaaS.Application.DTOs.BodegaDto
@{
    ViewData["Title"] = $"Editar Bodega — {Model.Nombre}";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="page-title">Editar Bodega</h1>
    <p class="text-muted mb-0">@Model.Nombre</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card glass-card">
      <div class="card-body p-4">
        <form asp-action="Editar" method="post">
          @Html.AntiForgeryToken()
          <input asp-for="Id" type="hidden" />

          <div class="mb-3">
            <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
          </div>

          <div class="mb-3">
            <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
          </div>

          <div class="mb-3">
            <label asp-for="Ubicacion" class="form-label fw-semibold">Ubicación</label>
            <input asp-for="Ubicacion" class="form-control" />
          </div>

          <div class="mb-4 form-check form-switch">
            <input asp-for="Activo" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="Activo" class="form-check-label">Bodega activa</label>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-save me-1"></i> Guardar Cambios
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
