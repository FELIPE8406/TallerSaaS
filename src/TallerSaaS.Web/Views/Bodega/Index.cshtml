@model List<TallerSaaS.Application.DTOs.BodegaDto>
@{
    ViewData["Title"] = "Bodegas";
}

@section Styles {
<style>
  @@media (max-width: 767px) {
    .mobile-cards-table thead { display: none; }
    .mobile-cards-table tbody { background: transparent !important; }
    .mobile-cards-table tbody tr {
      display: flex;
      flex-direction: column;
      margin-bottom: 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1rem;
      background: var(--surface);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .mobile-cards-table tbody td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border-subtle);
      text-align: right;
    }
    .mobile-cards-table tbody td::before {
      content: attr(data-label);
      font-weight: 600;
      color: var(--text-muted);
      font-size: 0.8rem;
      text-transform: uppercase;
      margin-right: 1rem;
      text-align: left;
    }
    .mobile-cards-table tbody td:last-child {
      flex-direction: column;
      border-bottom: none;
      padding-bottom: 0;
      padding-top: 1rem;
      gap: 0.5rem;
    }
    .mobile-cards-table td[data-label="Acciones"]::before { display: none; }
    .mobile-cards-table td[data-label="Acciones"] .btn {
      width: 100%;
      margin: 0 !important;
      justify-content: center;
    }
    .btn-mobile-full { width: 100% !important; }
    .glass-card { background: transparent !important; border: none !important; box-shadow: none !important; padding: 0 !important; }
  }
</style>
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
  <div>
    <h1 class="page-title">🏗️ Bodegas</h1>
    <p class="text-muted mb-0">Gestión de almacenes y ubicaciones de inventario</p>
  </div>
  <a asp-action="Crear" class="btn btn-primary btn-mobile-full">
    <i class="bi bi-plus-circle me-1"></i> Nueva Bodega
  </a>
</div>

@if (TempData["Exito"] != null)
{
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

<div class="card glass-card">
  <div class="card-body p-0">
    @if (!Model.Any())
    {
      <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🏗️</div>
        <p class="mt-2">No hay bodegas configuradas aún.</p>
        <a asp-action="Crear" class="btn btn-primary btn-sm">Crear primera bodega</a>
      </div>
    }
    else
    {
      <div class="table-responsive bg-transparent border-0">
        <table class="table table-hover align-middle mb-0 mobile-cards-table w-100">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Descripción</th>
              <th>Ubicación</th>
              <th class="text-center">Productos</th>
              <th class="text-center">Estado</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var b in Model)
            {
              <tr>
                <td data-label="Nombre"><span class="fw-bold text-primary">@b.Nombre</span></td>
                <td data-label="Descripción"><small class="text-muted">@(b.Descripcion ?? "—")</small></td>
                <td data-label="Ubicación"><small>@(b.Ubicacion ?? "—")</small></td>
                <td data-label="Productos" class="text-md-center">
                  <span class="badge bg-secondary">@b.TotalProductos</span>
                </td>
                <td data-label="Estado" class="text-md-center">
                  @if (b.Activo)
                  {
                    <span class="badge bg-success">Activa</span>
                  }
                  else
                  {
                    <span class="badge bg-secondary">Inactiva</span>
                  }
                </td>
                <td data-label="Acciones" class="text-md-center">
                  <a asp-action="Editar" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary me-md-1">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <a asp-action="Movimientos" asp-route-bodegaId="@b.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left-right"></i> Movimientos
                  </a>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>

@* Acceso rápido a traslados *@
<div class="mt-4 mt-md-3 d-flex flex-column flex-md-row justify-content-md-end gap-2">
  <a asp-action="Traslado" class="btn btn-outline-warning btn-mobile-full m-0">
    <i class="bi bi-arrow-left-right me-1"></i> Transferir Stock
  </a>
  <a asp-action="Movimientos" class="btn btn-outline-secondary btn-mobile-full m-0">
    <i class="bi bi-clock-history me-1"></i> Ver Movimientos
  </a>
</div>
