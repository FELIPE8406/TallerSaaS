@model List<TallerSaaS.Application.DTOs.BodegaDto>
@{
    ViewData["Title"] = "Bodegas";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="page-title">🏗️ Bodegas</h1>
    <p class="text-muted mb-0">Gestión de almacenes y ubicaciones de inventario</p>
  </div>
  <a asp-action="Crear" class="btn btn-primary">
    <i class="bi bi-plus-circle me-1"></i> Nueva Bodega
  </a>
</div>

@if (TempData["Exito"] != null)
{
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

<div class="card glass-card">
  <div class="card-body p-0">
    @if (!Model.Any())
    {
      <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🏗️</div>
        <p class="mt-2">No hay bodegas configuradas aún.</p>
        <a asp-action="Crear" class="btn btn-primary btn-sm">Crear primera bodega</a>
      </div>
    }
    else
    {
      <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
          <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Ubicación</th>
            <th class="text-center">Productos</th>
            <th class="text-center">Estado</th>
            <th class="text-center">Acciones</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var b in Model)
          {
            <tr>
              <td><span class="fw-bold text-primary">@b.Nombre</span></td>
              <td><small class="text-muted">@(b.Descripcion ?? "—")</small></td>
              <td><small>@(b.Ubicacion ?? "—")</small></td>
              <td class="text-center">
                <span class="badge bg-secondary">@b.TotalProductos</span>
              </td>
              <td class="text-center">
                @if (b.Activo)
                {
                  <span class="badge bg-success">Activa</span>
                }
                else
                {
                  <span class="badge bg-secondary">Inactiva</span>
                }
              </td>
              <td class="text-center">
                <a asp-action="Editar" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary me-1">
                  <i class="bi bi-pencil"></i> Editar
                </a>
                <a asp-action="Movimientos" asp-route-bodegaId="@b.Id" class="btn btn-sm btn-outline-secondary">
                  <i class="bi bi-arrow-left-right"></i> Movimientos
                </a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>

@* Acceso rápido a traslados *@
<div class="mt-3 text-end">
  <a asp-action="Traslado" class="btn btn-outline-warning">
    <i class="bi bi-arrow-left-right me-1"></i> Transferir Stock entre Bodegas
  </a>
  <a asp-action="Movimientos" class="btn btn-outline-secondary ms-2">
    <i class="bi bi-clock-history me-1"></i> Ver todos los Movimientos
  </a>
</div>
