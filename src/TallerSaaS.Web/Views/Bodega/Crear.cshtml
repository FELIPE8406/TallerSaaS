@model TallerSaaS.Application.DTOs.BodegaDto
@{
    ViewData["Title"] = "Nueva Bodega";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="page-title">Nueva Bodega</h1>
    <p class="text-muted mb-0">Registra un nuevo almacén de inventario</p>
  </div>
  <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card glass-card">
      <div class="card-body p-4">
        <form asp-action="Crear" method="post">
          @Html.AntiForgeryToken()

          <div class="mb-3">
            <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
            <input asp-for="Nombre" class="form-control" placeholder="Ej: Bodega Principal" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
          </div>

          <div class="mb-3">
            <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="2"
                      placeholder="Descripción opcional de la bodega"></textarea>
          </div>

          <div class="mb-4">
            <label asp-for="Ubicacion" class="form-label fw-semibold">Ubicación / Dirección</label>
            <input asp-for="Ubicacion" class="form-control" placeholder="Ej: Bodega norte, Piso 2" />
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-plus-circle me-1"></i> Crear Bodega
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
